{
  "name": "@silicon/cli",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "sgl": "./src/sigil_cli.ts"
  },
  "scripts": {
    "sgl": "bun run src/sigil_cli.ts",
    "build:sgl": "bun run scripts/build-binary.ts",
    "build:binaries": "bun run scripts/build-binary.ts linux-x86_64 linux-aarch64 macos-x86_64 macos-aarch64",
    "package:release": "bun run scripts/package-release.ts",
    "test": "bun test",
    "test:native": "bun test --timeout 60000 src/native",
    "test:selfhost": "bun test --timeout 120000 src/native/selfhost.test.ts"
  },
  "dependencies": {
    "@silicon/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.14.2"
  }
}
