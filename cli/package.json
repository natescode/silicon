{
  "name": "@silicon/cli",
  "version": "0.1",
  "type": "module",
  "bin": {
    "sgl": "./src/sigil_cli.ts"
  },
  "scripts": {
    "sgl": "bun run src/sigil_cli.ts",
    "build:sigilc": "bun build --compile src/sigil_cli.ts --outfile dist/sigilc",
    "test": "bun test",
    "test:native": "bun test --timeout 60000 src/native",
    "test:selfhost": "bun test --timeout 120000 src/native/selfhost.test.ts"
  },
  "dependencies": {
    "@silicon/compiler": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.14.2"
  }
}
