{
  "name": "sigil",
  "version": "0.1",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:properties": "bun test --timeout 60000 tests/properties",
    "test:fuzz": "bun test --timeout 120000 tests/fuzz",
    "boot:build": "bun run scripts/build-boot.ts",
    "boot:run": "bun run scripts/run-boot.ts",
    "stage1:build": "bun run scripts/build-stage1.ts",
    "stage1:run": "bun run scripts/run-silicon.ts",
    "compile": "bun run src/index.ts",
    "sgl": "bun run src/sigil_cli.ts",
    "build-types": "bunx ohm generateBundles --withTypes src/silicon-simple.ohm",
    "opt-wasm": "bun run ./binaryen-version_117/wasm-opt.js ../dist/bin.wasm",
    "playground": "bun run playground/server.ts",
    "loc": "bunx cloc . --exclude-dir node_modules,dist,build --exclude-ext json,lock,md,yml"
  },
  "devDependencies": {
    "@ohm-js/cli": "^2.0.0",
    "@types/bun": "latest",
    "@types/node": "^20.14.2",
    "fast-check": "^4.8.0",
    "ohm-js": "^17.1.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "binaryen": "^117.0.0",
    "wabt": "^1.0.39"
  }
}