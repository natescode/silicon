{
  "name": "@silicon/compiler",
  "version": "0.1",
  "type": "module",
  "types": "etc/sigil.d.ts",
  "exports": {
    ".": "./src/api.ts",
    "./native": "./src/native.ts",
    "./pipeline": "./src/pipeline.ts"
  },
  "scripts": {
    "types:emit": "tsc -p tsconfig.types.json || true",
    "api:extract": "npm run types:emit && api-extractor run --local",
    "api:check": "npm run types:emit && api-extractor run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run api:extract && changeset publish",
    "test": "bun test",
    "test:properties": "bun test --timeout 60000 tests/properties",
    "test:fuzz": "bun test --timeout 120000 tests/fuzz",
    "test:qbe": "bun test --timeout 60000 src/codegen/qbe",
    "test:backends": "bun test --timeout 60000 src/e2e/backends.test.ts",
    "bench:parser": "bun run bench/parse-bench.ts",
    "bench:incremental": "bun run bench/incremental-bench.ts",
    "compile": "bun run src/index.ts",
    "build:sigilc": "bash scripts/build-sigilc.sh",
    "opt-wasm": "bun run ./binaryen-version_117/wasm-opt.js ../dist/bin.wasm",
    "loc": "bunx cloc . --exclude-dir node_modules,dist,build --exclude-ext json,lock,md,yml"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/bun": "latest",
    "@types/node": "^20.14.2",
    "fast-check": "^4.8.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "binaryen": "^117.0.0",
    "wabt": "^1.0.39"
  }
}
