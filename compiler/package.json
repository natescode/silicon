{
  "name": "sigil",
  "version": "0.1",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:properties": "bun test --timeout 60000 tests/properties",
    "compile": "bun run src/index.ts",
    "sgl": "bun run src/sigil_cli.ts",
    "build-types": "bunx ohm generateBundles --withTypes src/silicon-simple.ohm",
    "opt-wasm": "bun run ./binaryen-version_117/wasm-opt.js ../dist/bin.wasm",
    "playground": "bun run playground/server.ts",
    "loc": "bunx cloc . --exclude-dir node_modules,dist,build --exclude-ext json,lock,md,yml"
  },
  "devDependencies": {
    "@ohm-js/cli": "^2.0.0",
    "@types/bun": "latest",
    "@types/node": "^20.14.2",
    "fast-check": "^4.8.0",
    "ohm-js": "^17.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "binaryen": "^117.0.0",
    "wabt": "^1.0.39"
  }
}