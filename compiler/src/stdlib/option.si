# SPDX-License-Identifier: MIT
# Phase 5a-1 — stdlib Option[T] type and helpers.
#
# Option models a value that may be absent.  Implemented as a parametric
# sum type (HM-lite); `Option[Int]` and `Option[Float]` are distinct
# nominal types — no T → Int coercion across instances.
#
#   @use 'option';
#   @fn pick:Int := &option_unwrap_or (&Some 42), 0;
#
# `&Some` and `&None` are the variant constructors generated by the
# parametric sum-type lowering.  Per CLAUDE.md the call site infers T
# automatically — no explicit `[Int]` at the call.

@type Option[T] := $Some value T | $None;

\\ option_unwrap_or[T] (Option[T], T)
option_unwrap_or[T] opt, dflt := {
    @match(opt, $Some v => v, $None => dflt)
};

\\ option_is_some[T] (Option[T])
option_is_some[T] opt := {
    @match(opt, $Some _v => @true, $None => @false)
};

\\ option_is_none[T] (Option[T])
option_is_none[T] opt := {
    @match(opt, $Some _v => @false, $None => @true)
};
