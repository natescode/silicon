# ── Utility helpers (pure) ──────────────────────────────────────────────
# Read UTF-8 bytes from the handler's exported memory; intern in StringPool.
# Pass `lenOrZero=0` for the Silicon string-literal layout (4-byte LE
# length header at ptr, body at ptr+4).  Pass an explicit `len` for a raw
# (ptr, len) range.
\\ @extern compiler_str_intern (Int, Int) -> Int;
\\ @extern compiler_watId (Int) -> Int;
\\ @extern compiler_freshId (Int) -> Int;
\\ @extern compiler_arg (Int, Int) -> Int;
\\ @extern compiler_choose (Int, Int, Int) -> Int;
# Fatal precondition guard — throws unless node has exactly `expected` args.
\\ @extern compiler_require_argc (Int, Int, Int) -> Void;
\\ @extern compiler_isVarName (Int) -> Int;

