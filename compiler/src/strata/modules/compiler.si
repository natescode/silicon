\\ @extern state_stratum () -> Int;
\\ @extern state_instance () -> Int;
\\ @extern state_has (Int, Int) -> Int;
\\ @extern state_get (Int, Int) -> Int;
\\ @extern state_set (Int, Int, Int) -> Void;

