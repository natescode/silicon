# ── Phase 5b: unsigned-integer operator overloads ───────────────────
# Routes `/`, `%`, `>>`, `<`, `>`, `<=`, `>=` to the *_u WASM instruction
# variants when both operands are unsigned.  Operators that share signed
# and unsigned semantics (+, -, *, ==, !=, &, |, ^, <<) fall back to the
# primary Int handlers since they emit the same WAT regardless.

@stratum DivideU8 := {
    &Compiler::register::typed_operator '/', 'UInt8';
    &Compiler::on::lower '/:UInt8', DivideU8_lower;
};
@fn DivideU8_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.div_u', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum ModuloU8 := {
    &Compiler::register::typed_operator '%', 'UInt8';
    &Compiler::on::lower '%:UInt8', ModuloU8_lower;
};
@fn ModuloU8_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.rem_u', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum ShiftRightU8 := {
    &Compiler::register::typed_operator '>>', 'UInt8';
    &Compiler::on::lower '>>:UInt8', ShiftRightU8_lower;
};
@fn ShiftRightU8_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.shr_u', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum LessThanU8 := {
    &Compiler::register::typed_operator '<', 'UInt8';
    &Compiler::on::lower '<:UInt8', LessThanU8_lower;
};
@fn LessThanU8_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.lt_u', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum GreaterThanU8 := {
    &Compiler::register::typed_operator '>', 'UInt8';
    &Compiler::on::lower '>:UInt8', GreaterThanU8_lower;
};
@fn GreaterThanU8_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.gt_u', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum LessThanOrEqualU8 := {
    &Compiler::register::typed_operator '<=', 'UInt8';
    &Compiler::on::lower '<=:UInt8', LessThanOrEqualU8_lower;
};
@fn LessThanOrEqualU8_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.le_u', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
