# SPDX-License-Identifier: MIT
# D-D-7a/b: Int (i32) arithmetic + comparison operators migrated to the new
# @stratum form.  Each Int operator's primary stratum is now a handler that
# builds an IRBinOp with the right WAT instruction.  Float and Int64
# overloads remain legacy (D-D-7c) — the typed-overload dispatch in
# lowerBinaryOp picks them when operands are Float/Int64; falls back to
# the migrated primary for Int.

@stratum Plus := {
    &Compiler::register::operator '+';
    &Compiler::on::lower '+', Plus_lower;
};
@fn Plus_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.add', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum Minus := {
    &Compiler::register::operator '-';
    &Compiler::on::lower '-', Minus_lower;
};
@fn Minus_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.sub', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum Multiply := {
    &Compiler::register::operator '*';
    &Compiler::on::lower '*', Multiply_lower;
};
@fn Multiply_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.mul', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum Divide := {
    &Compiler::register::operator '/';
    &Compiler::on::lower '/', Divide_lower;
};
@fn Divide_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.div_s', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum Modulo := {
    &Compiler::register::operator '%';
    &Compiler::on::lower '%', Modulo_lower;
};
@fn Modulo_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.rem_s', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum Equal := {
    &Compiler::register::operator '==';
    &Compiler::on::lower '==', Equal_lower;
};
@fn Equal_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.eq', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum NotEqual := {
    &Compiler::register::operator '!=';
    &Compiler::on::lower '!=', NotEqual_lower;
};
@fn NotEqual_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.ne', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum LessThan := {
    &Compiler::register::operator '<';
    &Compiler::on::lower '<', LessThan_lower;
};
@fn LessThan_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.lt_s', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum GreaterThan := {
    &Compiler::register::operator '>';
    &Compiler::on::lower '>', GreaterThan_lower;
};
@fn GreaterThan_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.gt_s', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum LessThanOrEqual := {
    &Compiler::register::operator '<=';
    &Compiler::on::lower '<=', LessThanOrEqual_lower;
};
@fn LessThanOrEqual_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.le_s', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

@stratum GreaterThanOrEqual := {
    &Compiler::register::operator '>=';
    &Compiler::on::lower '>=', GreaterThanOrEqual_lower;
};
@fn GreaterThanOrEqual_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'i32.ge_s', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'right', 0))),
        (&compiler::compiler_str_intern 'i32', 0);

# ── D-D-7c: Float overloads migrated to the new @stratum form ──────────
# Each `register::typed_operator '<op>', 'Float'` puts the stratum under
# the compound key `${op}:Float`.  The typed on::lower (registered under
# the same compound key) fires for Float operands; the migrated Int
# primary handles Int operands.

@stratum PlusFloat := {
    &Compiler::register::typed_operator '+', 'Float';
    &Compiler::on::lower '+:Float', PlusFloat_lower;
};
@fn PlusFloat_lower node:Int :=
    &compiler::ir_makeBinOp
        (&compiler::compiler_str_intern 'f32.add', 0),
        (&compiler::compiler_lowerExpr (&compiler::compiler_ast_node_field node, (&compiler::compiler_str_intern 'left', 0))),
