# Phase 4 (@defer) — basic end-of-body cleanup.
# Acquires a resource, runs some work, and schedules cleanup via @defer.
# The cleanup call is appended to the function body at lowering time.
@extern acquire:Int;
@extern release used:Int;
@extern noop x:Int;

@fn run := {
    @local handle:Int := &acquire;
    &@defer &release handle;
    &noop handle
};
