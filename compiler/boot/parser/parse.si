# Hand-written predictive parser for Silicon — bootstrap-plan §Phase 1.
#
#   parse(src_ptr, src_len, toks_vec) -> ast_vec
#
# Consumes the token stream from boot/parser/lex.si and produces the
# flat AST encoding defined in boot/parser/ast.si.
#
# Mutable parser state lives in module-level @vars so individual
# rule functions don't have to thread (src, toks, ast, cursor) through
# every call.  This matches the bootstrap plan's "shared cursor"
# sketch and keeps each rule function under 20 lines.
#
# Scope of this slice (subsequent commits extend):
#   ✓ integer literal
#   ✓ namespace (single ident, plus a.b / a::b chains)
#   ✓ binary expression (flat left-fold)
#   ✓ function call &name args
#   ✓ paren-grouped expression
#   ☐ string literal, float, bool — payload-encoded but unwrapped
#   ☐ block, definition, doc comment — next commit

@use '../std/vec.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';

# ── Parser state ─────────────────────────────────────────────────────
@var P_SRC:Int  := 0;
@var P_LEN:Int  := 0;
@var P_TOKS:Int := 0;
@var P_AST:Int  := 0;
@var P_CUR:Int  := 0;          # current token index (0..tok_count)

# ── Token cursor helpers ─────────────────────────────────────────────

@fn p_tok_count:Int := { ((&vec_len P_TOKS) / 3) };

# peek_kind / peek_off / peek_len for the current token.
@fn p_peek_kind:Int := { &vec_get P_TOKS, (P_CUR * 3) };
@fn p_peek_off:Int  := { &vec_get P_TOKS, (P_CUR * 3 + 1) };
@fn p_peek_len:Int  := { &vec_get P_TOKS, (P_CUR * 3 + 2) };

# peek at lookahead (current + n).
@fn p_lookahead_kind:Int n:Int := { &vec_get P_TOKS, ((P_CUR + n) * 3) };

# Consume the current token, advancing the cursor.
@fn p_advance := { P_CUR = P_CUR + 1; };

# ── Parse rules ──────────────────────────────────────────────────────
#
# Each parse_* function returns the AST index of the produced node.
# AST_NONE (-1) signals a parse failure / no match.
# Functions assume the caller has placed the cursor on the first token
# of their production.

# parse_int_lit — current token must be TOK_NUM_DEC; emits AST_INT_LIT.
# Decodes the decimal text by walking the source bytes.
@fn parse_int_lit:Int := {
  @local off := &p_peek_off;
  @local len := &p_peek_len;
  @local v   := 0;
  @local i   := 0;
  &@loop (i < len), {
    @local b := &WASM::i32_load8_u (P_SRC + off + i);
    # Underscore separators are allowed; skip them.
    &@if (b != 95), { v = (v * 10) + (b - 48); };
    i = i + 1;
  };
  @local node := &vec_offset P_AST;
  P_AST = &ast_int_lit P_AST, v;
  &p_advance;
  node
};

# parse_float_lit — TOK_NUM_FLOAT; we preserve the source text by
# storing (off, len) rather than parsing to an f32 here.
@fn parse_float_lit:Int := {
  @local off := &p_peek_off;
  @local len := &p_peek_len;
  @local node := &vec_offset P_AST;
  P_AST = &ast_float_lit P_AST, off, len;
  &p_advance;
  node
};

# parse_string_lit — TOK_STR.  The token text includes the surrounding
# `'` quotes; we strip them so the AST stores only the payload bytes.
@fn parse_string_lit:Int := {
  @local off := &p_peek_off;
  @local len := &p_peek_len;
  @local node := &vec_offset P_AST;
  P_AST = &ast_string_lit P_AST, (off + 1), (len - 2);
  &p_advance;
  node
};

# parse_bool_lit — TOK_KEYWORD whose text is `@true` or `@false`.
# Caller checks the text before dispatching here.
@fn parse_bool_lit:Int value:Int := {
  @local node := &vec_offset P_AST;
  P_AST = &ast_bool_lit P_AST, value;
  &p_advance;
  node
};

# Compare a (off, len) source span with a fixed ASCII byte sequence
# `bytes[0..n]`.  Returns 1 if equal.  Used by parse_bool_lit dispatch.
@fn span_eq:Int off:Int, len:Int, lit_ptr:Int, lit_len:Int := {
  # Use Int (not Bool) for the flag so reassignment and the function
  # return type stay coherent — Bool only auto-coerces in arithmetic.
  @local ok := 1;
  &@if (len != lit_len), { ok = 0; };
  @local i := 0;
  &@loop ((ok * (i < len)) == 1), {
    @local sb := &WASM::i32_load8_u (P_SRC + off + i);
    @local lb := &WASM::i32_load8_u (lit_ptr + i);
    &@if (sb != lb), { ok = 0; };
    i = i + 1;
  };
  ok
};

# parse_namespace — current token must be TOK_IDENT.
# Eagerly chews TOK_NS_SEP IDENT pairs to handle `a.b`, `a::b::c`.
@fn parse_namespace:Int := {
  @local node := &vec_offset P_AST;
  @local count_slot := node + 1;
  P_AST = &ast_namespace_start P_AST;          # placeholder n_segs=0

  # Read off/len into locals BEFORE the call.  Inlining `(&p_peek_off)`
  # / `(&p_peek_len)` directly in the call args caused the Silicon
  # codegen to mis-evaluate them when assignment to P_AST happens —
  # likely an arg-evaluation-order interaction.  Capturing first is
  # both safer and more readable.
  @local off1 := &p_peek_off;
  @local len1 := &p_peek_len;
  P_AST = &ast_namespace_seg P_AST, off1, len1;
  @local segs := 1;
  &p_advance;

  &@loop 1, {
    &@if ((&p_peek_kind) != TOK_NS_SEP), { &@break };
    &p_advance;
    &@if ((&p_peek_kind) != TOK_IDENT), { &@break };
    @local off2 := &p_peek_off;
    @local len2 := &p_peek_len;
    P_AST = &ast_namespace_seg P_AST, off2, len2;
    segs = segs + 1;
    &p_advance;
  };

  &ast_patch_at P_AST, count_slot, segs;
  node
};

# parse_paren_or_atom — handle parenthesised expressions or unwrap
# a leading-`(` ExpressionStart.  Returns the inner node.
@fn parse_paren:Int := {
  &p_advance;                                  # consume '('
  @local inner := &parse_expression_start;
  &@if ((&p_peek_kind) == TOK_RPAREN), { &p_advance; };
  inner
};

# parse_function_call — current token is TOK_AMP.  Reads &name then a
# comma-separated arg list of ExpressionStarts until a terminator.
#
# Args are parsed BEFORE the call header is emitted: their sub-records
# would otherwise interleave with the header's arg-index slots and
# silently corrupt the call layout.  Collected arg indices go into a
# temp vec, then we emit `[CALL, callee, n_args, arg0, ...]` as one
# contiguous block.
@fn parse_function_call:Int := {
  &p_advance;                                  # consume '&'

  # ── Callee: keyword (`&@if`) or namespace (`&web::log`, `&add`) ──
  @local callee_kind := &p_peek_kind;
  @local callee := AST_NONE;
  &@if (callee_kind == TOK_KEYWORD),
    {
      callee = &vec_offset P_AST;
      @local count_slot := callee + 1;
      P_AST = &ast_namespace_start P_AST;
      P_AST = &ast_namespace_seg P_AST, (&p_peek_off), (&p_peek_len);
      &ast_patch_at P_AST, count_slot, 1;
      &p_advance;
    },
    {
      &@if (callee_kind == TOK_IDENT), { callee = &parse_namespace; };
    };

  # ── Args: parse to a temp vec to avoid interleaving with the call
  # header's arg-index slots.
  @local arg_idxs := &vec_new;
  &@loop 1, {
    @local k := &p_peek_kind;
    &@if (k == TOK_SEMI),   { &@break };
    &@if (k == TOK_RPAREN), { &@break };
    &@if (k == TOK_RBRACE), { &@break };
    &@if (k == TOK_RBRACK), { &@break };
    &@if (k == TOK_COMMA),  { &@break };       # leading separator
    &@if (k == TOK_EOF),    { &@break };
    # An operator immediately after the callee means the call has
    # no args and the operator belongs to the surrounding expression
    # (e.g. `&k + &k` parses as BinaryOp(+, &k, &k)).  Operators
    # appearing *between* args are consumed by parse_expression_start
    # as part of that arg's binop chain — they only terminate the
    # arg list when they're the very next token.
    &@if (k == TOK_OPERATOR), { &@break };
    @local arg := &parse_expression_start;
    arg_idxs = &vec_push arg_idxs, arg;
    &@if ((&p_peek_kind) == TOK_COMMA), { &p_advance; }, { &@break };
  };

  @local n_args := &vec_len arg_idxs;

  # ── Emit the contiguous call record ──
  @local call_node := &vec_offset P_AST;
  P_AST = &ast_call_start P_AST, callee, n_args;
  @local j := 0;
  &@loop (j < n_args), {
    P_AST = &ast_call_arg P_AST, (&vec_get arg_idxs, j);
    j = j + 1;
  };
  call_node
};

# parse_array_lit — `$[ expr, expr, ... ]`.  Caller has confirmed the
# current token is TOK_DOLLAR followed by TOK_LBRACK.
@fn parse_array_lit:Int := {
  &p_advance;                                  # consume '$'
  &p_advance;                                  # consume '['
  @local elems := &vec_new;
  &@loop 1, {
    @local k := &p_peek_kind;
    &@if (k == TOK_RBRACK), { &@break };
    &@if (k == TOK_EOF),    { &@break };
    @local e := &parse_expression_start;
    elems = &vec_push elems, e;
    &@if ((&p_peek_kind) == TOK_COMMA), { &p_advance; }, { &@break };
  };
  &@if ((&p_peek_kind) == TOK_RBRACK), { &p_advance; };
  @local n := &vec_len elems;
  @local node := &vec_offset P_AST;
  P_AST = &ast_array_start P_AST, n;
  @local i := 0;
  &@loop (i < n), {
    P_AST = &ast_array_elem P_AST, (&vec_get elems, i);
    i = i + 1;
  };
  node
};

# parse_tuple_lit — `$( expr, expr, ... )`.
@fn parse_tuple_lit:Int := {
  &p_advance;                                  # consume '$'
  &p_advance;                                  # consume '('
  @local elems := &vec_new;
  &@loop 1, {
    @local k := &p_peek_kind;
    &@if (k == TOK_RPAREN), { &@break };
    &@if (k == TOK_EOF),    { &@break };
    @local e := &parse_expression_start;
    elems = &vec_push elems, e;
    &@if ((&p_peek_kind) == TOK_COMMA), { &p_advance; }, { &@break };
  };
  &@if ((&p_peek_kind) == TOK_RPAREN), { &p_advance; };
  @local n := &vec_len elems;
  @local node := &vec_offset P_AST;
  P_AST = &ast_tuple_start P_AST, n;
  @local i := 0;
  &@loop (i < n), {
    P_AST = &ast_tuple_elem P_AST, (&vec_get elems, i);
    i = i + 1;
  };
  node
};

# parse_object_lit — `${ key=expr, key=expr, ... }`.  Keys are bare
# identifiers (the grammar uses typedIdentifier; we store the bare
# name + length and treat the optional type annotation as ignored
# for Stage 1 ergonomics).
@fn parse_object_lit:Int := {
  &p_advance;                                  # consume '$'
  &p_advance;                                  # consume '{'
  # Pair layout: parallel arrays of key off/len/val to keep memory
  # use predictable.
  @local key_offs := &vec_new;
  @local key_lens := &vec_new;
  @local vals     := &vec_new;
  &@loop 1, {
    @local k := &p_peek_kind;
    &@if (k == TOK_RBRACE), { &@break };
    &@if (k == TOK_EOF),    { &@break };
    &@if (k != TOK_IDENT),  { &@break };       # malformed
    @local key_off := &p_peek_off;
    @local key_len := &p_peek_len;
    &p_advance;
    # Optional `:Type` on the key — consume and ignore.
    &parse_optional_type;
    &@if ((&p_peek_kind) != TOK_EQ), { &@break };
    &p_advance;
    @local v := &parse_expression_start;
    key_offs = &vec_push key_offs, key_off;
    key_lens = &vec_push key_lens, key_len;
    vals     = &vec_push vals, v;
    &@if ((&p_peek_kind) == TOK_COMMA), { &p_advance; }, { &@break };
  };
  &@if ((&p_peek_kind) == TOK_RBRACE), { &p_advance; };
  @local n := &vec_len vals;
  @local node := &vec_offset P_AST;
  P_AST = &ast_object_start P_AST, n;
  @local i := 0;
  &@loop (i < n), {
    P_AST = &ast_object_pair P_AST,
              (&vec_get key_offs, i),
              (&vec_get key_lens, i),
              (&vec_get vals, i);
    i = i + 1;
  };
  node
};

# parse_dollar — `$` followed by `[`, `(`, `{`, or an identifier
# (variant declarator).
@fn parse_dollar:Int := {
  @local next := &p_lookahead_kind 1;
  &@if (next == TOK_LBRACK), { &@return (&parse_array_lit); };
  &@if (next == TOK_LPAREN), { &@return (&parse_tuple_lit); };
  &@if (next == TOK_LBRACE), { &@return (&parse_object_lit); };
  &@if (next == TOK_IDENT),  { &@return (&parse_variant_decl); };
  # Stand-alone `$` isn't valid in Stage 1; skip and return AST_NONE.
  &p_advance;
  AST_NONE
};

# parse_variant_decl — `$Variant field:Type, field:Type`.  Caller has
# already verified the next token after `$` is TOK_IDENT.
@fn parse_variant_decl:Int := {
  &p_advance;                                  # consume '$'
  @local name_off := &p_peek_off;
  @local name_len := &p_peek_len;
  &p_advance;                                  # consume Variant
  # Parallel arrays for field (name, type) spans.
  @local f_name_off := &vec_new;
  @local f_name_len := &vec_new;
  @local f_type_off := &vec_new;
  @local f_type_len := &vec_new;
  &@loop 1, {
    @local k := &p_peek_kind;
    &@if (k != TOK_IDENT), { &@break };
    @local foff := &p_peek_off;
    @local flen := &p_peek_len;
    &p_advance;
    &parse_optional_type;
    f_name_off = &vec_push f_name_off, foff;
    f_name_len = &vec_push f_name_len, flen;
    f_type_off = &vec_push f_type_off, P_TYPE_OFF;
    f_type_len = &vec_push f_type_len, P_TYPE_LEN;
    &@if ((&p_peek_kind) == TOK_COMMA), { &p_advance; }, { &@break };
  };
  @local n := &vec_len f_name_off;
  @local node := &vec_offset P_AST;
  P_AST = &ast_variant_start P_AST, name_off, name_len, n;
  @local i := 0;
  &@loop (i < n), {
    P_AST = &ast_variant_field P_AST,
              (&vec_get f_name_off, i),
              (&vec_get f_name_len, i),
              (&vec_get f_type_off, i),
              (&vec_get f_type_len, i);
    i = i + 1;
  };
  node
};

# parse_block — `{` Item* trailing? `}`.  Each Item ends with `;`; the
# optional trailing expression has no `;`.  Same temp-vec trick as call
# args: stmt indices collected to a temp vec so the AST_BLOCK header
# stays contiguous.
@fn parse_block:Int := {
  &p_advance;                                   # consume '{'
  @local stmts := &vec_new;
  @local trailing := AST_NONE;

  &@loop 1, {
    @local k := &p_peek_kind;
    &@if (k == TOK_RBRACE), { &@break };
    &@if (k == TOK_EOF),    { &@break };
    @local node := &parse_element_inner;        # parses one Item-or-trailing
    @local after := &p_peek_kind;
    &@if (after == TOK_SEMI),
      {
        stmts = &vec_push stmts, node;
        &p_advance;                             # eat ';'
      },
      {
        # No semicolon → this is the trailing expression.
        trailing = node;
        &@break;
      };
  };

  &@if ((&p_peek_kind) == TOK_RBRACE), { &p_advance; };

  @local has_trailing := 0;
  &@if (trailing != AST_NONE), { has_trailing = 1; };
  @local n_stmts := &vec_len stmts;

  @local node := &vec_offset P_AST;
  P_AST = &ast_block_start P_AST, n_stmts, has_trailing;
  @local i := 0;
  &@loop (i < n_stmts), {
    P_AST = &ast_block_cell P_AST, (&vec_get stmts, i);
    i = i + 1;
  };
  &@if (has_trailing == 1), { P_AST = &ast_block_cell P_AST, trailing; };
  node
};

# Source-literal byte strings for the keyword bool-lit dispatcher.
# We keep them as Silicon string literals (which carry length + UTF-8
# bytes); span_eq compares the *source-buffer* slice against the
# literal payload starting at (str_ptr s) + 4.
@fn lit_true_ptr:Int  := { (&str_ptr '@true')  + 4 };
@fn lit_false_ptr:Int := { (&str_ptr '@false') + 4 };
@fn lit_op_ptr:Int    := { (&str_ptr '@stratum_operator') + 4 };
@fn lit_kw_ptr:Int    := { (&str_ptr '@stratum_keyword')  + 4 };

# parse_expression_end — one ExpressionEnd: literal, namespace, call,
# parenthesised expression, block, or $-literal.
@fn parse_expression_end:Int := {
  @local k := &p_peek_kind;
  @local node := AST_NONE;
  &@if (k == TOK_NUM_DEC),   { node = &parse_int_lit; };
  &@if (k == TOK_NUM_FLOAT), { node = &parse_float_lit; };
  &@if (k == TOK_STR),       { node = &parse_string_lit; };
  &@if (k == TOK_IDENT),     { node = &parse_namespace; };
  &@if (k == TOK_AMP),       { node = &parse_function_call; };
  &@if (k == TOK_LPAREN),    { node = &parse_paren; };
  &@if (k == TOK_LBRACE),    { node = &parse_block; };
  &@if (k == TOK_DOLLAR),    { node = &parse_dollar; };
  &@if (k == TOK_KEYWORD), {
    @local off := &p_peek_off;
    @local len := &p_peek_len;
    &@if ((&span_eq off, len, (&lit_true_ptr), 5) == 1), { node = &parse_bool_lit 1; };
    &@if ((&span_eq off, len, (&lit_false_ptr), 6) == 1), { node = &parse_bool_lit 0; };
  };
  node
};

# parse_expression_start — ExpressionEnd (BinOp ExpressionEnd)* — flat,
# no precedence (left-associative fold).
@fn parse_expression_start:Int := {
  @local lhs := &parse_expression_end;
  &@loop 1, {
    &@if ((&p_peek_kind) != TOK_OPERATOR), { &@break };
    @local op_off := &p_peek_off;
    @local op_len := &p_peek_len;
    &p_advance;
    @local rhs := &parse_expression_end;
    @local new_node := &vec_offset P_AST;
    P_AST = &ast_bin_op P_AST, op_off, op_len, lhs, rhs;
    lhs = new_node;
  };
  lhs
};

# parse_type_annotation — `:` IDENT.  Returns (off, len) of the type
# name via two module-level shadows because Silicon has no tuple
# returns and using a vec for two cells is gratuitous.
@var P_TYPE_OFF:Int := 0;
@var P_TYPE_LEN:Int := 0;

@fn parse_optional_type := {
  P_TYPE_OFF = 0;
  P_TYPE_LEN = 0;
  &@if ((&p_peek_kind) == TOK_COLON), {
    &p_advance;
    &@if ((&p_peek_kind) == TOK_IDENT), {
      P_TYPE_OFF = &p_peek_off;
      P_TYPE_LEN = &p_peek_len;
      &p_advance;
    };
  };
};

# parse_param_literal — one ParamLiteral, emitting AST_PARAMETER
# (name + optional TypeAnnotation) so the serializer can match
# Stage 0's `Parameter` JSON shape.
#
# Captures peek_off / peek_len into LOCALS first, then advances and
# calls parse_optional_type.  Inlining the peek calls inside the
# constructor call let parse_optional_type's `&p_advance` execute
# BEFORE the peek args were read, leaving the captured offsets
# pointing at a later token (the `:` or even past it).  Subtle.
@fn parse_param_literal:Int := {
  &@if ((&p_peek_kind) != TOK_IDENT), { &@return AST_NONE; };
  @local name_off := &p_peek_off;
  @local name_len := &p_peek_len;
  &p_advance;
  &parse_optional_type;
  @local type_off := P_TYPE_OFF;
  @local type_len := P_TYPE_LEN;
  @local node := &vec_offset P_AST;
  P_AST = &ast_parameter P_AST, name_off, name_len, type_off, type_len;
  node
};

# parse_definition — `@kw name [GenericParams?] [ParamLiteral,*]
#                    [:= ExpressionStart]`.  Caller has already
# verified the current token is TOK_KEYWORD.
@fn parse_definition:Int := {
  @local kw_off := &p_peek_off;
  @local kw_len := &p_peek_len;
  &p_advance;                                  # consume `@kw`

  # Definition name — must be an identifier (typedIdentifier).
  @local name_off := 0;
  @local name_len := 0;
  &@if ((&p_peek_kind) == TOK_IDENT), {
    name_off = &p_peek_off;
    name_len = &p_peek_len;
    &p_advance;
  };

  # Optional type annotation on the name.
  &parse_optional_type;
  @local type_off := P_TYPE_OFF;
  @local type_len := P_TYPE_LEN;

  # Generic params — `[T, U]`.  Skipped lexically for now (consumed
  # but not stored in the AST).  Stage 2 will tag them.
  &@if ((&p_peek_kind) == TOK_LBRACK), {
    &@loop 1, {
      &p_advance;
      &@if ((&p_peek_kind) == TOK_RBRACK), { &p_advance; &@break };
      &@if ((&p_peek_kind) == TOK_EOF),    { &@break };
    };
  };

  # ParamLiteral,* — comma-separated.  Collected to a temp vec so the
  # AST_DEFINITION header stays contiguous.
  @local params := &vec_new;
  &@loop 1, {
    @local k := &p_peek_kind;
    &@if (k == TOK_COLONEQ), { &@break };
    &@if (k == TOK_SEMI),    { &@break };
    &@if (k == TOK_RBRACE),  { &@break };
    &@if (k == TOK_EOF),     { &@break };
    @local p := &parse_param_literal;
    &@if (p == AST_NONE), { &@break };
    params = &vec_push params, p;
    &@if ((&p_peek_kind) == TOK_COMMA), { &p_advance; }, { &@break };
  };

  # Optional binding — `:= ExpressionStart`.
  @local binding := AST_NONE;
  &@if ((&p_peek_kind) == TOK_COLONEQ), {
    &p_advance;
    binding = &parse_expression_start;
  };

  @local n_params := &vec_len params;
  @local node := &vec_offset P_AST;
  P_AST = &ast_definition_start P_AST,
            kw_off, kw_len, name_off, name_len, type_off, type_len, n_params;
  @local i := 0;
  &@loop (i < n_params), {
    P_AST = &ast_definition_cell P_AST, (&vec_get params, i);
    i = i + 1;
  };
  P_AST = &ast_definition_cell P_AST, binding;
  node
};

# parse_doc_comment — TOK_DOC, content from `## ` to end-of-line.
@fn parse_doc_comment:Int := {
  @local off := &p_peek_off;
  @local len := &p_peek_len;
  @local node := &vec_offset P_AST;
  P_AST = &ast_doc_comment P_AST, off, len;
  &p_advance;
  node
};

# parse_assignment_or_expression — if the upcoming tokens look like
# `namespace = expr`, build an AST_ASSIGNMENT.  Otherwise fall through
# to a normal expression.
@fn parse_maybe_assignment:Int := {
  # Detect a 2-token lookahead pattern: TOK_IDENT (TOK_NS_SEP TOK_IDENT)* TOK_EQ.
  # Walk the cursor forward without advancing P_CUR — read by index.
  @local i := P_CUR;
  &@if ((&vec_get P_TOKS, (i * 3)) != TOK_IDENT), { &@return (&parse_expression_start); };
  i = i + 1;
  &@loop 1, {
    &@if ((&vec_get P_TOKS, (i * 3)) != TOK_NS_SEP), { &@break };
    i = i + 1;
    &@if ((&vec_get P_TOKS, (i * 3)) != TOK_IDENT), { &@return (&parse_expression_start); };
    i = i + 1;
  };
  &@if ((&vec_get P_TOKS, (i * 3)) != TOK_EQ), { &@return (&parse_expression_start); };

  # Confirmed: this is an Assignment.  Parse target + `=` + value.
  @local target := &parse_namespace;
  &p_advance;                                  # consume `=`
  @local value := &parse_expression_start;
  @local node := &vec_offset P_AST;
  P_AST = &ast_assignment P_AST, target, value;
  node
};

# parse_elaboration — `@stratum_operator NAME ( 'sym', NodeName ) = { ... }`
# or `@stratum_keyword NAME ( 'name', NodeName ) = { ... }`.  Caller has
# already verified the leading TOK_KEYWORD is one of the stratum forms
# (via span_eq) and supplies elab_kind (0 = operator, 1 = keyword).
@fn parse_elaboration:Int elab_kind:Int := {
  &p_advance;                                  # consume @stratum_*

  # Stratum name (an identifier).
  @local name_off := 0;
  @local name_len := 0;
  &@if ((&p_peek_kind) == TOK_IDENT), {
    name_off = &p_peek_off;
    name_len = &p_peek_len;
    &p_advance;
  };

  # Consume `(`.
  &@if ((&p_peek_kind) == TOK_LPAREN), { &p_advance; };

  # Symbol string literal — strip the surrounding quotes.
  @local sym_off := 0;
  @local sym_len := 0;
  &@if ((&p_peek_kind) == TOK_STR), {
    @local raw_off := &p_peek_off;
    @local raw_len := &p_peek_len;
    sym_off = raw_off + 1;
    sym_len = raw_len - 2;
    &p_advance;
  };

  # Comma.
  &@if ((&p_peek_kind) == TOK_COMMA), { &p_advance; };

  # Node-param identifier.
  @local np_off := 0;
  @local np_len := 0;
  &@if ((&p_peek_kind) == TOK_IDENT), {
    np_off = &p_peek_off;
    np_len = &p_peek_len;
    &p_advance;
  };

  # Consume `)`.
  &@if ((&p_peek_kind) == TOK_RPAREN), { &p_advance; };

  # Consume `=` (single Eq, not :=).
  &@if ((&p_peek_kind) == TOK_EQ), { &p_advance; };

  # Body is a Block.
  @local semantics := AST_NONE;
  &@if ((&p_peek_kind) == TOK_LBRACE), { semantics = &parse_block; };

  @local node := &vec_offset P_AST;
  P_AST = &ast_elaboration P_AST, elab_kind, name_off, name_len,
            sym_off, sym_len, np_off, np_len, semantics;
  node
};

# parse_element_inner — one Item or trailing-expression, WITHOUT
# consuming the optional trailing `;`.  Used by parse_block (which
# needs to inspect the post-element token to decide statement vs
# trailing).
@fn parse_element_inner:Int := {
  @local k := &p_peek_kind;
  &@if (k == TOK_DOC),     { &@return (&parse_doc_comment); };
  &@if (k == TOK_KEYWORD), {
    @local off := &p_peek_off;
    @local len := &p_peek_len;
    # Stratum-defining keywords get their own form (Elaboration).
    &@if ((&span_eq off, len, (&lit_op_ptr), 17) == 1),
      { &@return (&parse_elaboration ELAB_OPERATOR); };
    &@if ((&span_eq off, len, (&lit_kw_ptr), 16) == 1),
      { &@return (&parse_elaboration ELAB_KEYWORD); };
    # @true / @false are keyword-formed expressions, not definitions.
    @local is_bool := (&span_eq off, len, (&lit_true_ptr), 5)
                    | (&span_eq off, len, (&lit_false_ptr), 6);
    &@if (is_bool == 1), { &@return (&parse_expression_start); };
    &@return (&parse_definition);
  };
  &@if (k == TOK_IDENT),   { &@return (&parse_maybe_assignment); };
  &parse_expression_start
};

# parse_element — top-level program element: definition or expression
# statement; consumes a trailing `;` when present.
@fn parse_element:Int := {
  @local node := &parse_element_inner;
  &@if ((&p_peek_kind) == TOK_SEMI), { &p_advance; };
  node
};

# parse_program — main entry.  Loops parse_element until EOF, then
# emits the AST_PROGRAM header.
@fn parse:Int src_ptr:Int, src_len:Int, toks:Int := {
  P_SRC  = src_ptr;
  P_LEN  = src_len;
  P_TOKS = toks;
  P_AST  = &vec_new;
  P_CUR  = 0;

  # First pass: parse elements, collecting their indices in a temp vec.
  # Doc comments (## …) are stripped here so the AST matches Stage 0,
  # which discards them at toAst time.  The parser still creates the
  # node so a future doc-preserving mode can keep it.
  @local elems := &vec_new;
  &@loop 1, {
    @local k := &p_peek_kind;
    &@if (k == TOK_EOF), { &@break };
    @local elem := &parse_element;
    &@if (elem == AST_NONE), { &p_advance; },
      {
        @local keep := 1;
        &@if ((&ast_kind P_AST, elem) == AST_DOC_COMMENT), { keep = 0; };
        &@if (keep == 1), { elems = &vec_push elems, elem; };
      };
  };

  # Emit the program header + elem list.
  @local prog_node := &vec_offset P_AST;
  @local n := &vec_len elems;
  P_AST = &ast_program_start P_AST, n;
  @local i := 0;
  &@loop (i < n), {
    P_AST = &ast_program_elem P_AST, (&vec_get elems, i);
    i = i + 1;
  };

  prog_node
};
