# AST → JSON serializer.
#
# Writes the flat-vec AST encoding from boot/parser/ast.si as JSON
# matching the shape Stage 0's toAst.ts produces (pre-elaboration —
# no `hook`, no `inferredType`, no `semantics`).
#
# Output goes to fd 1 via boot/std/io.si.  Stage 0's JSON.stringify
# pretty-prints with 2-space indent; for the Phase 2 gate we emit the
# same indentation so a literal byte-wise diff suffices.
#
# Supported node kinds (slice 1 of N):
#   AST_PROGRAM, AST_DEFINITION, AST_INT_LIT, AST_BOOL_LIT,
#   AST_STRING_LIT, AST_FLOAT_LIT, AST_NAMESPACE, AST_BIN_OP,
#   AST_CALL, AST_BLOCK.
# Remaining kinds (variant decls, object/tuple/array lits, doc
# comments, assignments) land in follow-up commits.

@use '../std/io.si';
@use '../parser/tokens.si';
@use '../parser/ast.si';
@use '../parser/parse.si';                     # for P_SRC / P_AST

# ── Low-level writers ────────────────────────────────────────────────

@fn jw_byte b:Int := { &write_byte 1, b; };
@fn jw_str  s:String := { &write_str  1, s; };

# Write `n` source bytes verbatim from the parse source buffer.
@fn jw_src off:Int, len:Int := {
  &write_bytes 1, (P_SRC + off), len;
};

# Write an unsigned decimal integer (caller handles sign).
@fn jw_uint n:Int := {
  &@if (n == 0), { &jw_byte 48; },              # '0'
  {
    # Build digits LSB-first into a small scratch array, then write
    # them MSB-first.  Max i32 decimal is 10 digits + sign.
    @local digits := &scratch_alloc 16;
    @local i := 0;
    @local v := n;
    &@loop (v > 0), {
      &WASM::i32_store8 (digits + i), ((v % 10) + 48);
      v = v / 10;
      i = i + 1;
    };
    @local j := i;
    &@loop (j > 0), {
      j = j - 1;
      &jw_byte (&WASM::i32_load8_u (digits + j));
    };
  };
};

# Write a signed decimal integer.
@fn jw_int n:Int := {
  &@if (n < 0), { &jw_byte 45; &jw_uint (0 - n); }, { &jw_uint n; };
};

# Write `n` spaces.  Indent is 2 * depth.
@fn jw_indent depth:Int := {
  @local i := 0;
  &@loop (i < depth), {
    &jw_byte 32;
    &jw_byte 32;
    i = i + 1;
  };
};

# ── JSON-quoted source span ──────────────────────────────────────────
# Writes "..." with the source bytes at (off..off+len), escaping
# `"`, `\`, and the common control bytes.  Bootstrap inputs are ASCII
# Silicon source so the basic escape suffices.

@fn jw_string_span off:Int, len:Int := {
  &jw_byte 34;                                  # opening "
  @local i := 0;
  &@loop (i < len), {
    @local b := &WASM::i32_load8_u (P_SRC + off + i);
    &@if (b == 34),
      { &jw_byte 92; &jw_byte 34; },            # \"
      { &@if (b == 92),
          { &jw_byte 92; &jw_byte 92; },        # \\
          { &@if (b == 10),
              { &jw_byte 92; &jw_byte 110; },   # \n
              { &@if (b == 9),
                  { &jw_byte 92; &jw_byte 116; },   # \t
                  { &@if (b == 13),
                      { &jw_byte 92; &jw_byte 114; },   # \r
                      { &jw_byte b; }; }; }; }; };
    i = i + 1;
  };
  &jw_byte 34;                                  # closing "
};

# Convenience: write a JSON string from a Silicon string literal.
@fn jw_string_lit s:String := {
  &jw_byte 34;
  &write_bytes 1, ((&str_ptr s) + 4), (&str_len s);
  &jw_byte 34;
};

# ── Node-kind dispatch ───────────────────────────────────────────────

@fn json_int_lit depth:Int, node:Int := {
  @local v := &ast_field P_AST, node, 1;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'IntLiteral';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'value';
  &jw_str ': ';
  # Stage 0 stores value as a STRING.
  &jw_byte 34;
  &jw_int v;
  &jw_byte 34;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'base';
  &jw_str ': ';
  &jw_string_lit 'decimal';
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;                                 # }
};

@fn json_bool_lit depth:Int, node:Int := {
  @local v := &ast_field P_AST, node, 1;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'BooleanLiteral';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'value';
  &jw_str ': ';
  &@if (v == 1), { &jw_str 'true'; }, { &jw_str 'false'; };
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

@fn json_string_lit depth:Int, node:Int := {
  @local off := &ast_field P_AST, node, 1;
  @local len := &ast_field P_AST, node, 2;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'StringLiteral';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'value';
  &jw_str ': ';
  &jw_string_span off, len;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

@fn json_float_lit depth:Int, node:Int := {
  @local off := &ast_field P_AST, node, 1;
  @local len := &ast_field P_AST, node, 2;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'FloatLiteral';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'value';
  &jw_str ': ';
  &jw_string_span off, len;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

@fn json_namespace depth:Int, node:Int := {
  @local segs := &ast_field P_AST, node, 1;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'Namespace';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'path';
  &jw_str ': [';
  &@if (segs > 0), { &jw_byte 10; };
  @local i := 0;
  &@loop (i < segs), {
    # Silicon has no operator precedence — `2 + i * 2` parses as
    # `(2 + i) * 2` (left-fold).  Explicit parens force the right
    # arithmetic.
    @local off := &ast_field P_AST, node, (2 + (i * 2));
    @local len := &ast_field P_AST, node, (3 + (i * 2));
    &jw_indent (depth + 2);
    &jw_string_span off, len;
    &@if ((i + 1) < segs), { &jw_str ','; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (segs > 0), { &jw_indent (depth + 1); };
  &jw_byte 93;                                  # ]
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

@fn json_bin_op depth:Int, node:Int := {
  @local op_off := &ast_field P_AST, node, 1;
  @local op_len := &ast_field P_AST, node, 2;
  @local left   := &ast_field P_AST, node, 3;
  @local right  := &ast_field P_AST, node, 4;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'BinaryOp';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'left';
  &jw_str ': ';
  &json_node (depth + 1), left;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'operator';
  &jw_str ': ';
  &jw_string_span op_off, op_len;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'right';
  &jw_str ': ';
  &json_node (depth + 1), right;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# Stage 0's FunctionCall is { type, name (Namespace), isBuiltin, args[] }.
# `name.path[0]` carrying a leading '@' marks a builtin (e.g. `&@if`).
@fn json_function_call depth:Int, node:Int := {
  @local callee := &ast_field P_AST, node, 1;
  @local n_args := &ast_field P_AST, node, 2;
  # Determine isBuiltin: peek at the first source byte of the callee's
  # first segment.
  @local first_off := &ast_field P_AST, callee, 2;
  @local is_builtin := 0;
  &@if ((&WASM::i32_load8_u (P_SRC + first_off)) == 64), { is_builtin = 1; };

  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'FunctionCall';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'name';
  &jw_str ': ';
  # Stage 0 stores `name` as a bare string for builtins (`&@if` →
  # name="@if") and as a Namespace object for user calls.
  &@if (is_builtin == 1),
    {
      @local first_len := &ast_field P_AST, callee, 3;
      &jw_string_span first_off, first_len;
    },
    { &json_namespace (depth + 1), callee; };
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'isBuiltin';
  &jw_str ': ';
  &@if (is_builtin == 1), { &jw_str 'true'; }, { &jw_str 'false'; };
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'args';
  &jw_str ': [';
  &@if (n_args > 0), { &jw_byte 10; };
  @local i := 0;
  &@loop (i < n_args), {
    @local arg := &ast_field P_AST, node, (3 + i);
    &jw_indent (depth + 2);
    &json_node (depth + 2), arg;
    &@if ((i + 1) < n_args), { &jw_str ','; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n_args > 0), { &jw_indent (depth + 1); };
  &jw_byte 93;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# ── Composite types: TypedIdentifier, TypeAnnotation, Binding ───────

@fn json_type_annotation depth:Int, type_off:Int, type_len:Int := {
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'TypeAnnotation';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'typename';
  &jw_str ': ';
  &jw_string_span type_off, type_len;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# json_typed_identifier — emits { type:"TypedIdentifier", name,
# typeAnnotation? }.  When type_len == 0, the annotation key is
# omitted to match Stage 0's `typedIdentifier` semantic action.
@fn json_typed_identifier depth:Int, name_off:Int, name_len:Int,
                            type_off:Int, type_len:Int := {
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'TypedIdentifier';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'name';
  &jw_str ': ';
  &jw_string_span name_off, name_len;
  &@if (type_len > 0), {
    &jw_str ',';
    &jw_byte 10;
    &jw_indent (depth + 1);
    &jw_string_lit 'typeAnnotation';
    &jw_str ': ';
    &json_type_annotation (depth + 1), type_off, type_len;
  };
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# json_parameter — { type:"Parameter", name, typeAnnotation, isLiteral }.
@fn json_parameter depth:Int, node:Int := {
  @local name_off := &ast_field P_AST, node, 1;
  @local name_len := &ast_field P_AST, node, 2;
  @local type_off := &ast_field P_AST, node, 3;
  @local type_len := &ast_field P_AST, node, 4;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'Parameter';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'name';
  &jw_str ': ';
  &jw_string_span name_off, name_len;
  &@if (type_len > 0), {
    &jw_str ',';
    &jw_byte 10;
    &jw_indent (depth + 1);
    &jw_string_lit 'typeAnnotation';
    &jw_str ': ';
    &json_type_annotation (depth + 1), type_off, type_len;
  };
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'isLiteral';
  &jw_str ': false';
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# json_binding — { type:"Binding", expression }.
@fn json_binding depth:Int, expr_node:Int := {
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'Binding';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'expression';
  &jw_str ': ';
  &json_node (depth + 1), expr_node;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# ── Definitions ──────────────────────────────────────────────────────

@fn json_definition depth:Int, node:Int := {
  @local kw_off   := &ast_field P_AST, node, 1;
  @local kw_len   := &ast_field P_AST, node, 2;
  @local name_off := &ast_field P_AST, node, 3;
  @local name_len := &ast_field P_AST, node, 4;
  @local type_off := &ast_field P_AST, node, 5;
  @local type_len := &ast_field P_AST, node, 6;
  @local n_params := &ast_field P_AST, node, 7;

  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'Definition';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'keyword';
  &jw_str ': ';
  &jw_string_span kw_off, kw_len;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'name';
  &jw_str ': ';
  &json_typed_identifier (depth + 1), name_off, name_len, type_off, type_len;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'params';
  &jw_str ': [';
  &@if (n_params > 0), { &jw_byte 10; };
  @local i := 0;
  &@loop (i < n_params), {
    @local p := &ast_field P_AST, node, (8 + i);
    &jw_indent (depth + 2);
    &json_parameter (depth + 2), p;
    &@if ((i + 1) < n_params), { &jw_str ','; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n_params > 0), { &jw_indent (depth + 1); };
  &jw_byte 93;                                  # ]
  @local binding := &ast_field P_AST, node, (8 + n_params);
  &@if (binding != AST_NONE), {
    &jw_str ',';
    &jw_byte 10;
    &jw_indent (depth + 1);
    &jw_string_lit 'binding';
    &jw_str ': ';
    &json_binding (depth + 1), binding;
  };
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# ── Block ────────────────────────────────────────────────────────────

@fn json_block depth:Int, node:Int := {
  @local n_stmts := &ast_field P_AST, node, 1;
  @local has_tr  := &ast_field P_AST, node, 2;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'Block';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'items';
  &jw_str ': [';
  &@if (n_stmts > 0), { &jw_byte 10; };
  @local i := 0;
  &@loop (i < n_stmts), {
    @local s := &ast_field P_AST, node, (3 + i);
    &jw_indent (depth + 2);
    &json_node (depth + 2), s;
    &@if ((i + 1) < n_stmts), { &jw_str ','; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n_stmts > 0), { &jw_indent (depth + 1); };
  &jw_byte 93;
  &@if (has_tr == 1), {
    &jw_str ',';
    &jw_byte 10;
    &jw_indent (depth + 1);
    &jw_string_lit 'trailing';
    &jw_str ': ';
    @local trailing := &ast_field P_AST, node, (3 + n_stmts);
    &json_node (depth + 1), trailing;
  };
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# ── Array / Tuple / Object literals ──────────────────────────────────

@fn json_collection_lit depth:Int, node:Int, type_name:String, key:String := {
  @local n := &ast_field P_AST, node, 1;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit type_name;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit key;
  &jw_str ': [';
  &@if (n > 0), { &jw_byte 10; };
  @local i := 0;
  &@loop (i < n), {
    @local e := &ast_field P_AST, node, (2 + i);
    &jw_indent (depth + 2);
    &json_node (depth + 2), e;
    &@if ((i + 1) < n), { &jw_str ','; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n > 0), { &jw_indent (depth + 1); };
  &jw_byte 93;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

@fn json_array_lit depth:Int, node:Int := {
  &json_collection_lit depth, node, 'ArrayLiteral', 'elements';
};

@fn json_tuple_lit depth:Int, node:Int := {
  &json_collection_lit depth, node, 'TupleLiteral', 'elements';
};

# json_object_lit — { type:"ObjectLiteral", properties: [KeyValuePair,...] }
@fn json_object_lit depth:Int, node:Int := {
  @local n := &ast_field P_AST, node, 1;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'ObjectLiteral';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'properties';
  &jw_str ': [';
  &@if (n > 0), { &jw_byte 10; };
  # Each pair occupies 3 cells: key_off, key_len, val_idx.
  @local i := 0;
  &@loop (i < n), {
    @local key_off := &ast_field P_AST, node, (2 + (i * 3));
    @local key_len := &ast_field P_AST, node, (3 + (i * 3));
    @local val     := &ast_field P_AST, node, (4 + (i * 3));
    &jw_indent (depth + 2);
    &jw_str '{';
    &jw_byte 10;
    &jw_indent (depth + 3);
    &jw_string_lit 'type';
    &jw_str ': ';
    &jw_string_lit 'KeyValuePair';
    &jw_str ',';
    &jw_byte 10;
    &jw_indent (depth + 3);
    &jw_string_lit 'key';
    &jw_str ': ';
    &json_typed_identifier (depth + 3), key_off, key_len, 0, 0;
    &jw_str ',';
    &jw_byte 10;
    &jw_indent (depth + 3);
    &jw_string_lit 'value';
    &jw_str ': ';
    &json_node (depth + 3), val;
    &jw_byte 10;
    &jw_indent (depth + 2);
    &jw_byte 125;
    &@if ((i + 1) < n), { &jw_str ','; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n > 0), { &jw_indent (depth + 1); };
  &jw_byte 93;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# ── Assignment ───────────────────────────────────────────────────────

@fn json_assignment depth:Int, node:Int := {
  @local target := &ast_field P_AST, node, 1;
  @local value  := &ast_field P_AST, node, 2;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'Assignment';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'target';
  &jw_str ': ';
  &json_node (depth + 1), target;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'value';
  &jw_str ': ';
  &json_node (depth + 1), value;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# ── VariantDecl ──────────────────────────────────────────────────────

@fn json_variant_decl depth:Int, node:Int := {
  @local name_off := &ast_field P_AST, node, 1;
  @local name_len := &ast_field P_AST, node, 2;
  @local n_fields := &ast_field P_AST, node, 3;
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'VariantDecl';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'name';
  &jw_str ': ';
  &jw_string_span name_off, name_len;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'fields';
  &jw_str ': [';
  &@if (n_fields > 0), { &jw_byte 10; };
  @local i := 0;
  &@loop (i < n_fields), {
    # Each field occupies 4 cells: name_off, name_len, type_off, type_len.
    @local f_off    := &ast_field P_AST, node, (4 + (i * 4));
    @local f_len    := &ast_field P_AST, node, (5 + (i * 4));
    @local f_toff   := &ast_field P_AST, node, (6 + (i * 4));
    @local f_tlen   := &ast_field P_AST, node, (7 + (i * 4));
    &jw_indent (depth + 2);
    &json_typed_identifier (depth + 2), f_off, f_len, f_toff, f_tlen;
    &@if ((i + 1) < n_fields), { &jw_str ','; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n_fields > 0), { &jw_indent (depth + 1); };
  &jw_byte 93;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# ── Elaboration ──────────────────────────────────────────────────────

@fn json_elaboration depth:Int, node:Int := {
  @local elab_kind := &ast_field P_AST, node, 1;
  @local name_off  := &ast_field P_AST, node, 2;
  @local name_len  := &ast_field P_AST, node, 3;
  @local sym_off   := &ast_field P_AST, node, 4;
  @local sym_len   := &ast_field P_AST, node, 5;
  @local np_off    := &ast_field P_AST, node, 6;
  @local np_len    := &ast_field P_AST, node, 7;
  @local semantics := &ast_field P_AST, node, 8;

  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'Elaboration';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'kind';
  &jw_str ': ';
  &@if (elab_kind == ELAB_OPERATOR),
    { &jw_string_lit 'operator'; },
    { &jw_string_lit 'keyword'; };
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'name';
  &jw_str ': ';
  &jw_string_span name_off, name_len;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'symbol';
  &jw_str ': ';
  # Stage 0 stores symbol as a StringLiteral object with the unquoted
  # payload as `value`.
  &jw_str '{';
  &jw_byte 10;
  &jw_indent (depth + 2);
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'StringLiteral';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 2);
  &jw_string_lit 'value';
  &jw_str ': ';
  &jw_string_span sym_off, sym_len;
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_byte 125;                                 # close symbol object
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'nodeParamName';
  &jw_str ': ';
  &jw_string_span np_off, np_len;
  &jw_str ',';
  &jw_byte 10;
  &jw_indent (depth + 1);
  &jw_string_lit 'semantics';
  &jw_str ': ';
  &json_node (depth + 1), semantics;
  &jw_byte 10;
  &jw_indent depth;
  &jw_byte 125;
};

# Mutual recursion forward decl is implicit (Silicon resolves by name).
@fn json_node depth:Int, node:Int := {
  @local k := &ast_kind P_AST, node;
  &@if (k == AST_INT_LIT),     { &json_int_lit depth, node; &@return 0; };
  &@if (k == AST_BOOL_LIT),    { &json_bool_lit depth, node; &@return 0; };
  &@if (k == AST_FLOAT_LIT),   { &json_float_lit depth, node; &@return 0; };
  &@if (k == AST_STRING_LIT),  { &json_string_lit depth, node; &@return 0; };
  &@if (k == AST_NAMESPACE),   { &json_namespace depth, node; &@return 0; };
  &@if (k == AST_BIN_OP),      { &json_bin_op depth, node; &@return 0; };
  &@if (k == AST_CALL),        { &json_function_call depth, node; &@return 0; };
  &@if (k == AST_BLOCK),       { &json_block depth, node; &@return 0; };
  &@if (k == AST_DEFINITION),  { &json_definition depth, node; &@return 0; };
  &@if (k == AST_ARRAY_LIT),   { &json_array_lit depth, node; &@return 0; };
  &@if (k == AST_TUPLE_LIT),   { &json_tuple_lit depth, node; &@return 0; };
  &@if (k == AST_OBJECT_LIT),  { &json_object_lit depth, node; &@return 0; };
  &@if (k == AST_ASSIGNMENT),  { &json_assignment depth, node; &@return 0; };
  &@if (k == AST_VARIANT),     { &json_variant_decl depth, node; &@return 0; };
  &@if (k == AST_ELABORATION), { &json_elaboration depth, node; &@return 0; };
  # Unsupported kind — emit a stub so output stays well-formed.
  &jw_string_lit 'unsupported';
  0
};

# Top-level: walk a Program and write the canonical JSON.
@fn json_program root:Int := {
  &jw_str '{';
  &jw_byte 10;
  &jw_indent 1;
  &jw_string_lit 'type';
  &jw_str ': ';
  &jw_string_lit 'Program';
  &jw_str ',';
  &jw_byte 10;
  &jw_indent 1;
  &jw_string_lit 'elements';
  &jw_str ': [';
  @local n := &ast_field P_AST, root, 1;
  &@if (n > 0), { &jw_byte 10; };
  @local i := 0;
  &@loop (i < n), {
    &jw_indent 2;
    @local elem := &ast_field P_AST, root, (2 + i);
    &json_node 2, elem;
    &@if ((i + 1) < n), { &jw_str ','; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n > 0), { &jw_indent 1; };
  &jw_str ']';
  &jw_byte 10;
  &jw_byte 125;
  &jw_byte 10;
};
