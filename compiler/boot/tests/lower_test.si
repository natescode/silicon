# End-to-end expression lowerer test.  Loads the strata bundle plus
# a tiny program from stdin, finds the first top-level expression
# statement, lowers it through boot/ir/lower.si, and prints the
# resulting IR record's (kind, op, left.kind, left.value,
# right.kind, right.value) on one line for the bun-side gate to
# diff.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';
@use '../ir/nodes.si';
@use '../elab/body.si';
@use '../elab/body_scope.si';
@use '../compiler_api/ctx.si';
@use '../elab/body_rich.si';
@use '../ir/lower.si';

@fn lw_write_int v:Int := {
  &@if (v < 0), { &write_byte 1, 45; v = 0 - v; };
  @local d4 := v / 10000;
  @local d3 := (v / 1000) - (d4 * 10);
  @local d2 := (v / 100)  - ((d4 * 100) + (d3 * 10));
  @local d1 := (v / 10)   - ((d4 * 1000) + (d3 * 100) + (d2 * 10));
  @local d0 := v - ((d4 * 10000) + (d3 * 1000) + (d2 * 100) + (d1 * 10));
  @local seen := 0;
  &@if (d4 > 0), { &write_byte 1, (48 + d4); seen = 1; };
  &@if ((seen == 1) + (d3 > 0) > 0), { &write_byte 1, (48 + d3); seen = 1; };
  &@if ((seen == 1) + (d2 > 0) > 0), { &write_byte 1, (48 + d2); seen = 1; };
  &@if ((seen == 1) + (d1 > 0) > 0), { &write_byte 1, (48 + d1); seen = 1; };
  &write_byte 1, (48 + d0);
};

@fn run := {
  @local cap := 65536;
  @local buf := &arena_alloc cap;
  @local total := 0;
  &@loop 1, {
    @local n := &read_bytes 0, (buf + total), (cap - total);
    &@if (n <= 0), { &@break };
    total = total + n;
    &@if (total >= cap), { &@break };
  };

  @local toks := &lex buf, total;
  @local prog := &parse buf, total, toks;
  &registry_init;
  &load_strata prog;
  &ir_init;

  # Find the first AST_BIN_OP or AST_BLOCK element in the program.
  # The user-test tail of stdin is expected to put one such
  # expression statement after all the strata definitions.
  @local n_elems := &ast_field P_AST, prog, 1;
  @local i := 0;
  @local target := AST_NONE;
  &@loop ((target == AST_NONE) * (i < n_elems) == 1), {
    @local elem := &ast_field P_AST, prog, (2 + i);
    @local k := &ast_kind P_AST, elem;
    &@if ((k == AST_BIN_OP) + (k == AST_BLOCK) > 0), { target = elem; };
    i = i + 1;
  };

  @local h := &lower_expr target;
  &@if (h == IR_NONE), {
    &write_str 1, 'no-ir';
    &write_byte 1, 10;
    &wasi_snapshot_preview1::proc_exit 0;
  };

  # Emit: kind=<n> op=<n> left=<kind>:<val> right=<kind>:<val>
  &write_str 1, 'kind='; &lw_write_int (&ir_kind h);
  @local k := &ir_kind h;
  &@if (k == IR_BINOP), {
    &write_str 1, ' op=';     &lw_write_int (&ir_field h, 1);
    @local lh := &ir_field h, 2;
    @local rh := &ir_field h, 3;
    &write_str 1, ' left=';   &lw_write_int (&ir_kind lh);
    &write_str 1, ':';        &lw_write_int (&ir_field lh, 1);
    &write_str 1, ' right=';  &lw_write_int (&ir_kind rh);
    &write_str 1, ':';        &lw_write_int (&ir_field rh, 1);
  };
  &@if (k == IR_I32_CONST), {
    &write_str 1, ' value=';  &lw_write_int (&ir_field h, 1);
  };
  &@if (k == IR_BLOCK), {
    @local n_children := &ir_block_count h;
    &write_str 1, ' n='; &lw_write_int n_children;
    @local ci := 0;
    &@loop (ci < n_children), {
      @local ch := &ir_block_child h, ci;
      &write_str 1, ' child[';
      &lw_write_int ci;
      &write_str 1, ']=';
      &lw_write_int (&ir_kind ch);
      ci = ci + 1;
    };
  };
  &write_byte 1, 10;

  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
