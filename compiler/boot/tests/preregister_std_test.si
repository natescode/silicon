# preregister_std_test — exercises preregister_std.si.
#
# Pass: "preregister-std OK", exit 0.
# Fail: "preregister-std FAIL <code>", exit 1.

@use '../std/io.si';
@use '../types/types.si';
@use '../types/ctx.si';
@use '../types/preregister_std.si';

@fn ps_put_int n:Int := {
  @local hundreds := (n / 100);
  @local tens     := ((n / 10) % 10);
  @local ones     := (n % 10);
  &@if (hundreds > 0),     { &write_byte 1, (hundreds + 48); };
  &@if (((hundreds > 0) | (tens > 0)) == 1), { &write_byte 1, (tens + 48); };
  &write_byte 1, (ones + 48);
};

@fn ps_die code:Int := {
  &write_str 1, 'preregister-std FAIL ';
  &ps_put_int code;
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 1;
};

# Assert a registered fn has the expected (n_params, p0, p1, p2, result).
@fn ps_check name:String, want_n:Int, want_p0:Int, want_p1:Int, want_p2:Int, want_r:Int, code:Int := {
  @local id := &fn_lookup_str name;
  &@if (id < 0), { &ps_die code; };
  &@if ((&fn_n_params id) != want_n),                  { &ps_die (code + 1); };
  &@if (((want_n >= 1) * ((&fn_param id, 0) != want_p0)) == 1), { &ps_die (code + 2); };
  &@if (((want_n >= 2) * ((&fn_param id, 1) != want_p1)) == 1), { &ps_die (code + 3); };
  &@if (((want_n >= 3) * ((&fn_param id, 2) != want_p2)) == 1), { &ps_die (code + 4); };
  &@if ((&fn_result id) != want_r),                    { &ps_die (code + 5); };
};

@fn run := {
  &types_init;
  &ctx_init;
  &preregister_std;

  &@if ((&fn_count) != 11), { &ps_die 1; };

  &ps_check 'alloc',         1, TYPE_INT_H,    0,             0,           TYPE_INT_H,     10;
  &ps_check 'alloc_array',   2, TYPE_INT_H,    TYPE_INT_H,    0,           TYPE_INT_H,     20;
  &ps_check 'arr_len',       1, TYPE_INT_H,    0,             0,           TYPE_INT_H,     30;
  &ps_check 'arr_load_i32',  2, TYPE_INT_H,    TYPE_INT_H,    0,           TYPE_INT_H,     40;
  &ps_check 'arr_load_f32',  2, TYPE_INT_H,    TYPE_INT_H,    0,           TYPE_FLOAT_H,   50;
  &ps_check 'arr_store_i32', 3, TYPE_INT_H,    TYPE_INT_H,    TYPE_INT_H,  TYPE_UNKNOWN_H, 60;
  &ps_check 'scratch_alloc', 1, TYPE_INT_H,    0,             0,           TYPE_INT_H,     70;
  &ps_check 'str_ptr',       1, TYPE_STRING_H, 0,             0,           TYPE_INT_H,     80;
  &ps_check 'str_len',       1, TYPE_STRING_H, 0,             0,           TYPE_INT_H,     90;
  &ps_check 'heap_get',      0, 0,             0,             0,           TYPE_INT_H,     100;
  &ps_check 'heap_set',      1, TYPE_INT_H,    0,             0,           TYPE_UNKNOWN_H, 110;

  # Unregistered name returns -1.
  &@if ((&fn_lookup_str 'bogus_never_registered') != (0 - 1)), { &ps_die 200; };

  &write_str 1, 'preregister-std OK';
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
