# types_test — exercises boot/types/types.si in isolation.
#
# Pass: "types OK", exit 0.
# Fail: "types FAIL <code>", exit 1.

@use '../std/io.si';
@use '../std/vec.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../types/types.si';

@fn t_put_int n:Int := {
  @local hundreds := (n / 100);
  @local tens     := ((n / 10) % 10);
  @local ones     := (n % 10);
  &@if (hundreds > 0),     { &write_byte 1, (hundreds + 48); };
  &@if (((hundreds > 0) | (tens > 0)) == 1), { &write_byte 1, (tens + 48); };
  &write_byte 1, (ones + 48);
};

@fn t_die code:Int := {
  &write_str 1, 'types FAIL ';
  &t_put_int code;
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 1;
};

@fn run := {
  &types_init;

  # ── Singletons + kinds ────────────────────────────────────────
  &@if ((&type_kind TYPE_INT_H) != SK_INT),         { &t_die 1; };
  &@if ((&type_kind TYPE_INT64_H) != SK_INT64),     { &t_die 2; };
  &@if ((&type_kind TYPE_FLOAT_H) != SK_FLOAT),     { &t_die 3; };
  &@if ((&type_kind TYPE_STRING_H) != SK_STRING),   { &t_die 4; };
  &@if ((&type_kind TYPE_BOOL_H) != SK_BOOL),       { &t_die 5; };
  &@if ((&type_kind TYPE_UNKNOWN_H) != SK_UNKNOWN), { &t_die 6; };

  # ── wasm_type_of ──────────────────────────────────────────────
  &@if ((&wasm_type_of TYPE_INT_H)     != TY_I32), { &t_die 10; };
  &@if ((&wasm_type_of TYPE_INT64_H)   != TY_I64), { &t_die 11; };
  &@if ((&wasm_type_of TYPE_FLOAT_H)   != TY_F32), { &t_die 12; };
  &@if ((&wasm_type_of TYPE_STRING_H)  != TY_I32), { &t_die 13; };
  &@if ((&wasm_type_of TYPE_BOOL_H)    != TY_I32), { &t_die 14; };
  &@if ((&wasm_type_of TYPE_UNKNOWN_H) != TY_I32), { &t_die 15; };

  # ── type_equals on singletons + composite ─────────────────────
  &@if ((&type_equals TYPE_INT_H, TYPE_INT_H) != 1),     { &t_die 20; };
  &@if ((&type_equals TYPE_INT_H, TYPE_FLOAT_H) != 0),   { &t_die 21; };
  &@if ((&type_equals TYPE_BOOL_H, TYPE_INT_H) != 0),    { &t_die 22; };

  # Array[Int] equals another Array[Int], but not Array[Bool].
  @local arr_int  := &type_new_array TYPE_INT_H;
  @local arr_int2 := &type_new_array TYPE_INT_H;
  @local arr_bool := &type_new_array TYPE_BOOL_H;
  &@if ((&type_equals arr_int, arr_int2) != 1),  { &t_die 30; };
  &@if ((&type_equals arr_int, arr_bool) != 0),  { &t_die 31; };
  &@if ((&wasm_type_of arr_int) != TY_I32),      { &t_die 32; };

  # Function((Int, Int) -> Int).
  @local pvec := &vec_new;
  pvec = &vec_push pvec, TYPE_INT_H;
  pvec = &vec_push pvec, TYPE_INT_H;
  @local fn_t  := &type_new_function TYPE_INT_H, pvec;
  @local fn_t2 := &type_new_function TYPE_INT_H, pvec;
  &@if ((&type_equals fn_t, fn_t2) != 1), { &t_die 40; };
  # Different result type.
  @local fn_void := &type_new_function TYPE_UNKNOWN_H, pvec;
  &@if ((&type_equals fn_t, fn_void) != 0), { &t_die 41; };

  # ── Predicates ────────────────────────────────────────────────
  &@if ((&is_numeric TYPE_INT_H)    != 1), { &t_die 50; };
  &@if ((&is_numeric TYPE_FLOAT_H)  != 1), { &t_die 51; };
  &@if ((&is_numeric TYPE_BOOL_H)   != 0), { &t_die 52; };
  &@if ((&is_numeric TYPE_STRING_H) != 0), { &t_die 53; };
  &@if ((&is_comparable TYPE_BOOL_H) != 1), { &t_die 60; };
  &@if ((&is_comparable TYPE_STRING_H) != 0), { &t_die 61; };
  &@if ((&is_equality_comparable TYPE_STRING_H) != 1), { &t_die 70; };
  &@if ((&is_equality_comparable TYPE_INT_H) != 1),    { &t_die 71; };
  &@if ((&is_equality_comparable arr_int) != 0),       { &t_die 72; };

  # ── parse_type_name ───────────────────────────────────────────
  # Parse a @fn with each known type as a param's annotation, then
  # look up each param's type span via parse_type_name.  Spans must
  # live in P_SRC so type_span_eq_lit can compare them.
  @local src := '@fn _ a:Int, b:Int32, c:Int64, d:Float, e:String, f:Bool, g:Void, h:i32, i:i64, j:f32, k:Widget := { 0 };';
  @local p := (&str_ptr src) + 4;
  @local n := &str_len src;
  @local toks := &lex p, n;
  @local prog := &parse p, n, toks;
  @local def := &ast_field P_AST, prog, 2;
  &@if ((&ast_kind P_AST, def) != AST_DEFINITION), { &t_die 80; };
  @local n_params := &ast_field P_AST, def, 7;
  &@if (n_params != 11), { &t_die 81; };
  # Each AST_PARAMETER has type span at fields 3 (off) and 4 (len).
  @local p0  := &ast_field P_AST, def, 8;
  &@if ((&parse_type_name (&ast_field P_AST, p0,  3), (&ast_field P_AST, p0,  4)) != TYPE_INT_H),     { &t_die 82; };
  @local p1  := &ast_field P_AST, def, 9;
  &@if ((&parse_type_name (&ast_field P_AST, p1,  3), (&ast_field P_AST, p1,  4)) != TYPE_INT_H),     { &t_die 83; };
  @local p2  := &ast_field P_AST, def, 10;
  &@if ((&parse_type_name (&ast_field P_AST, p2,  3), (&ast_field P_AST, p2,  4)) != TYPE_INT64_H),   { &t_die 84; };
  @local p3  := &ast_field P_AST, def, 11;
  &@if ((&parse_type_name (&ast_field P_AST, p3,  3), (&ast_field P_AST, p3,  4)) != TYPE_FLOAT_H),   { &t_die 85; };
  @local p4  := &ast_field P_AST, def, 12;
  &@if ((&parse_type_name (&ast_field P_AST, p4,  3), (&ast_field P_AST, p4,  4)) != TYPE_STRING_H),  { &t_die 86; };
  @local p5  := &ast_field P_AST, def, 13;
  &@if ((&parse_type_name (&ast_field P_AST, p5,  3), (&ast_field P_AST, p5,  4)) != TYPE_BOOL_H),    { &t_die 87; };
  @local p6  := &ast_field P_AST, def, 14;
  &@if ((&parse_type_name (&ast_field P_AST, p6,  3), (&ast_field P_AST, p6,  4)) != TYPE_UNKNOWN_H), { &t_die 88; };
  @local p7  := &ast_field P_AST, def, 15;
  &@if ((&parse_type_name (&ast_field P_AST, p7,  3), (&ast_field P_AST, p7,  4)) != TYPE_INT_H),     { &t_die 89; };
  @local p8  := &ast_field P_AST, def, 16;
  &@if ((&parse_type_name (&ast_field P_AST, p8,  3), (&ast_field P_AST, p8,  4)) != TYPE_INT64_H),   { &t_die 90; };
  @local p9  := &ast_field P_AST, def, 17;
  &@if ((&parse_type_name (&ast_field P_AST, p9,  3), (&ast_field P_AST, p9,  4)) != TYPE_FLOAT_H),   { &t_die 91; };
  @local p10 := &ast_field P_AST, def, 18;
  &@if ((&parse_type_name (&ast_field P_AST, p10, 3), (&ast_field P_AST, p10, 4)) != TYPE_NONE),      { &t_die 92; };

  &write_str 1, 'types OK';
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
