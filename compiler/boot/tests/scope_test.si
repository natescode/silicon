# Locals + scope round-trip test.  Drives a + b through the
# lowerer with `a` bound to local 0 and `b` to local 1, then emits
# the WAT and asserts it.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';
@use '../ir/nodes.si';
@use '../elab/body.si';
@use '../elab/body_scope.si';
@use '../compiler_api/ctx.si';
@use '../elab/body_rich.si';
@use '../ir/lower.si';
@use '../emit/wat.si';

@fn run := {
  @local cap := 65536;
  @local buf := &arena_alloc cap;
  @local total := 0;
  &@loop 1, {
    @local n := &read_bytes 0, (buf + total), (cap - total);
    &@if (n <= 0), { &@break };
    total = total + n;
    &@if (total >= cap), { &@break };
  };

  @local toks := &lex buf, total;
  @local prog := &parse buf, total, toks;
  &registry_init;
  &load_strata prog;
  &ir_init;
  &scope_init;

  # Find the first AST_BIN_OP in the program — the test expression
  # is appended after the strata bundle as `a + b;` (or similar).
  @local n_elems := &ast_field P_AST, prog, 1;
  @local i := 0;
  @local target := AST_NONE;
  &@loop ((target == AST_NONE) * (i < n_elems) == 1), {
    @local elem := &ast_field P_AST, prog, (2 + i);
    @local k := &ast_kind P_AST, elem;
    &@if ((k == AST_BIN_OP) + (k == AST_NAMESPACE) + (k == AST_BLOCK) > 0),
      { target = elem; };
    i = i + 1;
  };

  # Walk the target tree to collect every single-segment Namespace
  # we encounter and bind each to a sequential local index in
  # first-seen order.  This synthesises the param/local table the
  # function-definition lowerer will eventually own.
  &collect_and_bind target;

  @local h := &lower_expr target;
  &emit_expr h;
  &wasi_snapshot_preview1::proc_exit 0;
};

# Bind every fresh single-segment Namespace under `node` to the next
# unused local index.
@fn collect_and_bind node:Int := {
  &@if (node < 0), { &@return 0; };
  @local k := &ast_kind P_AST, node;

  &@if (k == AST_NAMESPACE), {
    @local n_segs := &ast_field P_AST, node, 1;
    &@if (n_segs == 1), {
      @local off := &ast_field P_AST, node, 2;
      @local len := &ast_field P_AST, node, 3;
      &@if ((&scope_lookup off, len) < 0), {
        @local idx := &vec_len LSCOPE_IDX;
        &scope_push off, len, idx;
      };
    };
  };

  &@if (k == AST_BIN_OP), {
    &collect_and_bind (&ast_field P_AST, node, 3);
    &collect_and_bind (&ast_field P_AST, node, 4);
  };

  &@if (k == AST_BLOCK), {
    @local n_stmts := &ast_field P_AST, node, 1;
    @local has_trailing := &ast_field P_AST, node, 2;
    @local i := 0;
    &@loop (i < n_stmts), {
      &collect_and_bind (&ast_field P_AST, node, (3 + i));
      i = i + 1;
    };
    &@if (has_trailing == 1), {
      &collect_and_bind (&ast_field P_AST, node, (3 + n_stmts));
    };
  };

  0
};

&run;
