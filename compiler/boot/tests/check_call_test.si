# check_call_test — slice 2e-iii FunctionCall type checking.
#
# Pass: "check-call OK", exit 0.
# Fail: "check-call FAIL <code>", exit 1.

@use '../std/io.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../types/types.si';
@use '../types/ctx.si';
@use '../types/errors.si';
@use '../types/preregister_std.si';
@use '../types/preregister_defs.si';
@use '../types/check.si';

@fn cc_put_int n:Int := {
  @local hundreds := (n / 100);
  @local tens     := ((n / 10) % 10);
  @local ones     := (n % 10);
  &@if (hundreds > 0),     { &write_byte 1, (hundreds + 48); };
  &@if (((hundreds > 0) | (tens > 0)) == 1), { &write_byte 1, (tens + 48); };
  &write_byte 1, (ones + 48);
};

@fn cc_die code:Int := {
  &write_str 1, 'check-call FAIL ';
  &cc_put_int code;
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 1;
};

@fn run := {
  &types_init;
  &errors_init;
  &ctx_init;
  &preregister_std;   # alloc, arr_*, str_*, heap_*

  # Build a tiny program defining `add(a:Int, b:Int):Int` so the fn
  # table has a user-defined signature alongside the std helpers.
  @local src := '@fn add:Int a:Int, b:Int := { (a + b) }; (&add 1, 2);';
  @local p := (&str_ptr src) + 4;
  @local n := &str_len src;
  @local toks := &lex p, n;
  @local prog := &parse p, n, toks;
  &preregister_defs prog;

  # Element 0 is the @fn add def; element 1 is the &add 1, 2 call.
  @local call_node := &ast_field P_AST, prog, 3;

  &@if ((&check_node call_node) != TYPE_INT_H), { &cc_die 10; };

  # Wrong arg type — should push EK_MISMATCH and return TYPE_INT_H
  # (the resolved result type).
  @local src2 := '(&add 1, @true);';
  @local p2 := (&str_ptr src2) + 4;
  @local n2 := &str_len src2;
  @local toks2 := &lex p2, n2;
  @local prog2 := &parse p2, n2, toks2;
  @local call2 := &ast_field P_AST, prog2, 2;

  @local errs_before := &err_count;
  &@if ((&check_node call2) != TYPE_INT_H),          { &cc_die 20; };
  &@if ((&err_count) != (errs_before + 1)),          { &cc_die 21; };
  &@if ((&err_kind errs_before) != EK_MISMATCH),     { &cc_die 22; };

  # std helper resolves: alloc(Int):Int
  @local src3 := '(&alloc 32);';
  @local p3 := (&str_ptr src3) + 4;
  @local n3 := &str_len src3;
  @local toks3 := &lex p3, n3;
  @local prog3 := &parse p3, n3, toks3;
  @local call3 := &ast_field P_AST, prog3, 2;
  &@if ((&check_node call3) != TYPE_INT_H), { &cc_die 30; };

  # Unknown callee — silent miss (no error pushed), TYPE_UNKNOWN_H.
  @local src4 := '(&never_defined 1);';
  @local p4 := (&str_ptr src4) + 4;
  @local n4 := &str_len src4;
  @local toks4 := &lex p4, n4;
  @local prog4 := &parse p4, n4, toks4;
  @local call4 := &ast_field P_AST, prog4, 2;
  @local errs_b2 := &err_count;
  &@if ((&check_node call4) != TYPE_UNKNOWN_H), { &cc_die 40; };
  &@if ((&err_count) != errs_b2),               { &cc_die 41; };

  &write_str 1, 'check-call OK';
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
