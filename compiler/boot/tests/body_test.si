# Body interpreter — Phase 4 slice 8 gate.
#
# Loads the full built-in strata bundle, then for each operator
# stratum runs interpret_body with synthetic operand handles and
# emits a single line describing the resulting IR node:
#
#   <symbol> <kind> <op> <left> <right>
#
# where <kind>/<op> are integer values from boot/ir/nodes.si and
# <left>/<right> are the seed handles (or IR_NONE).  The bun-side
# gate maps Stage 0's bodyTemplate to the same shape and diffs.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';
@use '../ir/nodes.si';
@use '../elab/body.si';

@let SEED_LEFT:Int  := 100;
@let SEED_RIGHT:Int := 200;

# Tiny base-10 writer (handles 0..32767).
@fn bt_write_int v:Int := {
  &@if (v < 0), { &write_byte 1, 45; v = 0 - v; };
  @local d4 := v / 10000;
  @local d3 := (v / 1000) - (d4 * 10);
  @local d2 := (v / 100)  - ((d4 * 100) + (d3 * 10));
  @local d1 := (v / 10)   - ((d4 * 1000) + (d3 * 100) + (d2 * 10));
  @local d0 := v - ((d4 * 10000) + (d3 * 1000) + (d2 * 100) + (d1 * 10));
  @local seen := 0;
  &@if (d4 > 0), { &write_byte 1, (48 + d4); seen = 1; };
  &@if ((seen == 1) + (d3 > 0) > 0), { &write_byte 1, (48 + d3); seen = 1; };
  &@if ((seen == 1) + (d2 > 0) > 0), { &write_byte 1, (48 + d2); seen = 1; };
  &@if ((seen == 1) + (d1 > 0) > 0), { &write_byte 1, (48 + d1); seen = 1; };
  &write_byte 1, (48 + d0);
};

@fn run := {
  @local cap := 65536;
  @local buf := &arena_alloc cap;
  @local total := 0;
  &@loop 1, {
    @local n := &read_bytes 0, (buf + total), (cap - total);
    &@if (n <= 0), { &@break };
    total = total + n;
    &@if (total >= cap), { &@break };
  };

  @local toks := &lex buf, total;
  @local prog := &parse buf, total, toks;
  &registry_init;
  &load_strata prog;
  &ir_init;

  # Walk operator registry in registration order — duplicates
  # collapse via dedup-by-symbol-first-wins (selection-sort tie
  # break tested in slice 4).
  @local seen_off := &vec_new;
  @local seen_len := &vec_new;
  @local n_op := &registry_op_count;
  @local i := 0;
  &@loop (i < n_op), {
    @local sym_off := &registry_op_sym_off i;
    @local sym_len := &registry_op_sym_len i;
    # Skip if symbol already seen.
    @local m := &vec_len seen_off;
    @local dup := 0;
    @local k := 0;
    &@loop ((dup == 0) * (k < m) == 1), {
      @local p_off := &vec_get seen_off, k;
      @local p_len := &vec_get seen_len, k;
      &@if ((&bl_span_eq_span sym_off, sym_len, p_off, p_len) == 1),
        { dup = 1; };
      k = k + 1;
    };
    &@if (dup == 0), {
      seen_off = &vec_push seen_off, sym_off;
      seen_len = &vec_push seen_len, sym_len;
      @local elab := &registry_op_elab i;
      @local sem  := &ast_field P_AST, elab, 8;
      @local np_o := &ast_field P_AST, elab, 6;
      @local np_l := &ast_field P_AST, elab, 7;
      &bi_set_node SEED_LEFT, SEED_RIGHT;
      @local h := &interpret_body sem, np_o, np_l;

      # Emit: <symbol> kind=<n> op=<n> l=<n> r=<n>
      &write_bytes 1, (P_SRC + sym_off), sym_len;
      &write_str 1, ' kind=';
      &@if (h == IR_NONE), {
        &write_str 1, 'none op=- l=- r=-';
      };
      &@if (h != IR_NONE), {
        &bt_write_int (&ir_kind h);
        @local kk := &ir_kind h;
        &@if (kk == IR_BINOP), {
          &write_str 1, ' op='; &bt_write_int (&ir_field h, 1);
          &write_str 1, ' l=';  &bt_write_int (&ir_field h, 2);
          &write_str 1, ' r=';  &bt_write_int (&ir_field h, 3);
        };
        &@if (kk == IR_UNOP), {
          &write_str 1, ' op='; &bt_write_int (&ir_field h, 1);
          &write_str 1, ' l=';  &bt_write_int (&ir_field h, 2);
          &write_str 1, ' r=-';
        };
        &@if (kk == IR_NULL), { &write_str 1, ' op=- l=- r=-'; };
      };
      &write_byte 1, 10;
    };
    i = i + 1;
  };

  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
