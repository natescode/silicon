# errors_test — exercises boot/types/errors.si in isolation.
#
# Pass: "errors OK", exit 0.
# Fail: "errors FAIL <code>", exit 1.

@use '../std/io.si';
@use '../std/vec.si';
@use '../types/types.si';
@use '../types/errors.si';

@fn e_put_int n:Int := {
  @local hundreds := (n / 100);
  @local tens     := ((n / 10) % 10);
  @local ones     := (n % 10);
  &@if (hundreds > 0),     { &write_byte 1, (hundreds + 48); };
  &@if (((hundreds > 0) | (tens > 0)) == 1), { &write_byte 1, (tens + 48); };
  &write_byte 1, (ones + 48);
};

@fn e_die code:Int := {
  &write_str 1, 'errors FAIL ';
  &e_put_int code;
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 1;
};

@fn run := {
  &types_init;
  &errors_init;
  &@if ((&err_count) != 0), { &e_die 1; };

  # Point P_SRC at a string literal so name spans render real text.
  # 'op_plus is here' — useful substrings via [off,len) pairs:
  #   "op_plus" → [0,7]
  #   "here"    → [11,4]
  @local src := 'op_plus is here';
  P_SRC = (&str_ptr src) + 4;

  # ── Factories + field accessors ─────────────────────────────
  @local id_m := &err_mismatch TYPE_INT_H, TYPE_FLOAT_H, 11, 4;
  &@if ((&err_kind id_m) != EK_MISMATCH),   { &e_die 10; };
  &@if ((&err_field id_m, 1) != TYPE_INT_H),   { &e_die 11; };
  &@if ((&err_field id_m, 2) != TYPE_FLOAT_H), { &e_die 12; };
  &@if ((&err_field id_m, 5) != 11),           { &e_die 13; };
  &@if ((&err_field id_m, 6) != 4),            { &e_die 14; };

  @local id_op := &err_invalid_operator 0, 7, TYPE_STRING_H, TYPE_INT_H, 11, 4;
  &@if ((&err_kind id_op) != EK_INVALID_OPERATOR),  { &e_die 20; };
  &@if ((&err_field id_op, 1) != TYPE_STRING_H),    { &e_die 21; };
  &@if ((&err_field id_op, 2) != TYPE_INT_H),       { &e_die 22; };
  &@if ((&err_field id_op, 3) != 0),                { &e_die 23; };
  &@if ((&err_field id_op, 4) != 7),                { &e_die 24; };

  @local id_u := &err_unbound 11, 4, 11, 4;
  &@if ((&err_kind id_u) != EK_UNBOUND), { &e_die 30; };

  @local id_ut := &err_unknown_type 11, 4, 11, 4;
  &@if ((&err_kind id_ut) != EK_UNKNOWN_TYPE), { &e_die 40; };

  @local arr_int := &type_new_array TYPE_INT_H;
  @local id_h := &err_heterogeneous TYPE_INT_H, arr_int, 0, 0;
  &@if ((&err_kind id_h) != EK_HETEROGENEOUS), { &e_die 50; };

  @local id_a := &err_annotation 11, 4, TYPE_INT_H, TYPE_BOOL_H, 11, 4;
  &@if ((&err_kind id_a) != EK_ANNOTATION),  { &e_die 60; };
  &@if ((&err_field id_a, 1) != TYPE_INT_H), { &e_die 61; };
  &@if ((&err_field id_a, 2) != TYPE_BOOL_H),{ &e_die 62; };

  @local id_i := &err_immutable 11, 4, 11, 4;
  &@if ((&err_kind id_i) != EK_IMMUTABLE), { &e_die 70; };

  &@if ((&err_count) != 7), { &e_die 80; };

  # ── Rendering ───────────────────────────────────────────────
  # Each err_write_msg writes one labelled line.  Spot-check the
  # full output below against a golden expected by the harness.
  &err_write_msg 1, id_m;     &write_byte 1, 10;
  &err_write_msg 1, id_op;    &write_byte 1, 10;
  &err_write_msg 1, id_u;     &write_byte 1, 10;
  &err_write_msg 1, id_ut;    &write_byte 1, 10;
  &err_write_msg 1, id_h;     &write_byte 1, 10;
  &err_write_msg 1, id_a;     &write_byte 1, 10;
  &err_write_msg 1, id_i;     &write_byte 1, 10;

  &write_str 1, 'errors OK';
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
