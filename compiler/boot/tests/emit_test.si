# End-to-end emit test.  Loads strata + a user expression from
# stdin, lowers to IR, emits stack-machine WAT instructions to
# stdout (one per line).  The bun-side gate diffs against an
# expected instruction sequence.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';
@use '../ir/nodes.si';
@use '../elab/body.si';
@use '../ir/lower.si';
@use '../emit/wat.si';

@fn run := {
  @local cap := 65536;
  @local buf := &arena_alloc cap;
  @local total := 0;
  &@loop 1, {
    @local n := &read_bytes 0, (buf + total), (cap - total);
    &@if (n <= 0), { &@break };
    total = total + n;
    &@if (total >= cap), { &@break };
  };

  @local toks := &lex buf, total;
  @local prog := &parse buf, total, toks;
  &registry_init;
  &load_strata prog;
  &ir_init;

  @local n_elems := &ast_field P_AST, prog, 1;
  @local i := 0;
  @local target := AST_NONE;
  &@loop ((target == AST_NONE) * (i < n_elems) == 1), {
    @local elem := &ast_field P_AST, prog, (2 + i);
    @local k := &ast_kind P_AST, elem;
    &@if ((k == AST_BIN_OP) + (k == AST_BLOCK) + (k == AST_INT_LIT) > 0),
      { target = elem; };
    i = i + 1;
  };

  @local h := &lower_expr target;
  &emit_expr h;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
