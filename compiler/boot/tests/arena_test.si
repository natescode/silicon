# Arena unit test.
#
# Build with `bun run scripts/build-boot.ts boot/tests/arena_test.si` and run
# under wasmer.  Prints "arena OK" on success, "arena FAIL <code>" otherwise.
#
# Why wrapped in a function: each `@let name := expr` at top level becomes a
# zero-arg function `$name` that runs `expr` on every call, not a one-shot
# binding evaluated at module init.  To exercise allocation order we need
# proper local bindings — only @local inside a function body gives us that.

@use '../std/io.si';
@use '../std/arena.si';

@fn run_arena_test := {
  @local base := &arena_save;
  @local a0   := &arena_alloc 16;
  @local a1   := &arena_alloc 32;
  &arena_reset base;
  @local a2   := &arena_alloc 16;

  # a2 should equal a0 (reset rewound the bump pointer past both allocs).
  &@if (a2 == a0),
    { &write_str 1, 'arena OK' },
    { &write_str 1, 'arena FAIL' };
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run_arena_test;
