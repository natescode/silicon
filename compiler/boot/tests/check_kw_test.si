# check_kw_test — slice 2e-v keyword call type checking.
#
# Pass: "check-kw OK", exit 0.
# Fail: "check-kw FAIL <code>", exit 1.

@use '../std/io.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../types/types.si';
@use '../types/ctx.si';
@use '../types/errors.si';
@use '../types/check.si';

@fn ck_put_int n:Int := {
  @local hundreds := (n / 100);
  @local tens     := ((n / 10) % 10);
  @local ones     := (n % 10);
  &@if (hundreds > 0),     { &write_byte 1, (hundreds + 48); };
  &@if (((hundreds > 0) | (tens > 0)) == 1), { &write_byte 1, (tens + 48); };
  &write_byte 1, (ones + 48);
};

@fn ck_die code:Int := {
  &write_str 1, 'check-kw FAIL ';
  &ck_put_int code;
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 1;
};

@fn ck_parse_top:Int src:String := {
  @local p := (&str_ptr src) + 4;
  @local n := &str_len src;
  @local toks := &lex p, n;
  @local prog := &parse p, n, toks;
  &ast_field P_AST, prog, 2
};

@fn run := {
  &types_init;
  &errors_init;
  &ctx_init;

  # ── @if cond, then  → then-branch type ────────────────────
  &@if ((&check_node (&ck_parse_top '&@if 1, { 42 };')) != TYPE_INT_H), { &ck_die 10; };

  # ── @if cond, then, else  matching → then type ────────────
  &@if ((&check_node (&ck_parse_top '&@if 1, { 1 }, { 2 };')) != TYPE_INT_H), { &ck_die 20; };

  # ── @if branch mismatch → EK_MISMATCH ─────────────────────
  @local errs := &err_count;
  &@if ((&check_node (&ck_parse_top '&@if 1, { 1 }, { @true };')) != TYPE_INT_H), { &ck_die 30; };
  &@if ((&err_count) != (errs + 1)),                                              { &ck_die 31; };
  &@if ((&err_kind errs) != EK_MISMATCH),                                         { &ck_die 32; };

  # ── @not → Int ─────────────────────────────────────────────
  &@if ((&check_node (&ck_parse_top '&@not 0;')) != TYPE_INT_H), { &ck_die 40; };

  # ── @nz → Int ──────────────────────────────────────────────
  &@if ((&check_node (&ck_parse_top '&@nz 42;')) != TYPE_INT_H), { &ck_die 50; };

  # ── @and → right operand type ─────────────────────────────
  &@if ((&check_node (&ck_parse_top '&@and 1, @true;')) != TYPE_BOOL_H), { &ck_die 60; };

  # ── @loop → Unknown (void) ────────────────────────────────
  &@if ((&check_node (&ck_parse_top '&@loop 1, { 1 };')) != TYPE_UNKNOWN_H), { &ck_die 70; };

  # ── @return value → Unknown ────────────────────────────────
  &@if ((&check_node (&ck_parse_top '&@return 5;')) != TYPE_UNKNOWN_H), { &ck_die 80; };

  &write_str 1, 'check-kw OK';
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
