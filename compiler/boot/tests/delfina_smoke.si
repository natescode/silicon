# Phase 1 smoke test for the bootstrap _start synthesis.
#
# Unlike every other boot/tests/*.si — which uses `@fn run := {...}; &run;`
# and is compiled by the TS Stage 0 (which already synthesises _start) —
# this file probes the BOOTSTRAP compiler's ability to wrap top-level
# statements into an export-able WASI entry point on its own.
#
# Source layout:
#   - WASI extern surface declared explicitly with the
#     `wasi_snapshot_preview1::` namespace prefix (the bootstrap doesn't
#     apply the filename-as-namespace convention the TS modules loader
#     uses, so the prefix has to be visible at the @extern site).
#   - boot/std/io.si — bundled in by the test harness, not @use'd here
#     (the bootstrap doesn't process @use; the harness assembles the
#     bundle on stdin).
#   - bare `&write_str` / `&write_byte` calls at top level — these are
#     what triggers the Phase 1 synthesis path.
#
# Expected: stage1.wasm compiles this to a WAT module whose lone
# `(func $_start (export "_start"))` writes "Delfina\n" to fd 1.

@extern wasi_snapshot_preview1::fd_write:Int
  fd:Int, iovs_ptr:Int, iovs_len:Int, nwritten_out:Int;
@extern wasi_snapshot_preview1::fd_read:Int
  fd:Int, iovs_ptr:Int, iovs_len:Int, nread_out:Int;
# Phase 4a: io.si's panic_stderr references proc_exit, so any
# bundle that includes io.si must also declare proc_exit (the
# bootstrap lowers every top-level @fn, even unreferenced ones).
@extern wasi_snapshot_preview1::proc_exit
  code:Int;

@let name:String := 'Delfina';

&write_str  1, name;
&write_byte 1, 10;
