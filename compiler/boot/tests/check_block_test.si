# check_block_test — slice 2e-iv Block + Assignment + inline Definition.
#
# Pass: "check-block OK", exit 0.
# Fail: "check-block FAIL <code>", exit 1.

@use '../std/io.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../types/types.si';
@use '../types/ctx.si';
@use '../types/errors.si';
@use '../types/preregister_defs.si';
@use '../types/check.si';

@fn cbk_put_int n:Int := {
  @local hundreds := (n / 100);
  @local tens     := ((n / 10) % 10);
  @local ones     := (n % 10);
  &@if (hundreds > 0),     { &write_byte 1, (hundreds + 48); };
  &@if (((hundreds > 0) | (tens > 0)) == 1), { &write_byte 1, (tens + 48); };
  &write_byte 1, (ones + 48);
};

@fn cbk_die code:Int := {
  &write_str 1, 'check-block FAIL ';
  &cbk_put_int code;
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 1;
};

@fn cbk_parse_top:Int src:String := {
  @local p := (&str_ptr src) + 4;
  @local n := &str_len src;
  @local toks := &lex p, n;
  @local prog := &parse p, n, toks;
  &ast_field P_AST, prog, 2
};

@fn run := {
  &types_init;
  &errors_init;
  &ctx_init;

  # ── Block with trailing expression returns its type ───────
  &@if ((&check_node (&cbk_parse_top '{ 1; 2; 42 };')) != TYPE_INT_H), { &cbk_die 10; };
  &@if ((&check_node (&cbk_parse_top '{ @true };'))     != TYPE_BOOL_H), { &cbk_die 11; };

  # ── Block without trailing → Unknown ──────────────────────
  &@if ((&check_node (&cbk_parse_top '{ 1; 2; };')) != TYPE_UNKNOWN_H), { &cbk_die 20; };

  # ── Inline @let binds the name in scope ───────────────────
  &@if ((&check_node (&cbk_parse_top '{ @let x:Int := 5; x };')) != TYPE_INT_H), { &cbk_die 30; };

  # ── Annotation mismatch pushes EK_ANNOTATION ──────────────
  @local errs := &err_count;
  &@if ((&check_node (&cbk_parse_top '{ @let y:Int := @true; y };')) != TYPE_INT_H), { &cbk_die 40; };
  &@if ((&err_count) != (errs + 1)),                                   { &cbk_die 41; };
  &@if ((&err_kind errs) != EK_ANNOTATION),                            { &cbk_die 42; };

  # ── Scope discipline: inner binding doesn't leak ──────────
  # Outer scope adds nothing for `z`; after the block, sym_lookup_str
  # must not see it.
  &@if ((&check_node (&cbk_parse_top '{ @let z:Int := 1; z };')) != TYPE_INT_H), { &cbk_die 50; };
  &@if ((&sym_lookup_str 'z') != TYPE_NONE), { &cbk_die 51; };

  # ── Immutable assignment is flagged ───────────────────────
  @local errs2 := &err_count;
  @local prog := &cbk_parse_top '@let k:Int := 7; k = 9;';
  # check_node on the top of `cbk_parse_top` only gets the first
  # element.  We need to check both elements manually here.
  @local p := (&str_ptr '@let k:Int := 7; k = 9;') + 4;
  @local n := &str_len '@let k:Int := 7; k = 9;';
  @local toks := &lex p, n;
  @local full := &parse p, n, toks;
  @local n_el := &ast_field P_AST, full, 1;
  @local idx := 0;
  &@loop (idx < n_el), {
    @local el := &ast_field P_AST, full, (2 + idx);
    &check_node el;
    idx = idx + 1;
  };
  &@if ((&err_count) != (errs2 + 1)), { &cbk_die 60; };
  &@if ((&err_kind errs2) != EK_IMMUTABLE), { &cbk_die 61; };

  &write_str 1, 'check-block OK';
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
