# strata2_test — smoke test for Strata 2.0 unified-form loader.
#
# Verifies that the loader recognises the new `@stratum Name := { ... }`
# unified form and registers `&Compiler::register::keyword` /
# `&Compiler::register::operator` calls from the body.
#
# Self-contained: no external piping required.  Embeds a small strata
# source bundle as a Silicon string literal, feeds it through the
# lex/parse/loader pipeline, and asserts the resulting registry shape.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';

@fn _start:Void := {
  # Source bundle: ONE @stratum unified-form definition registering
  # one keyword + one operator AND a handler in each of the four
  # phases (decl, callSite, annotation, module_finalize).
  @local src := '@stratum Demo := { &Compiler::register::keyword \'@demo_kw\'; &Compiler::register::operator \'@@\'; &Compiler::on::decl \'@demo_kw\', { 1 }; &Compiler::on::callSite \'demo_fn\', { 2 }; &Compiler::on::annotation \'@@demo_ann\', { 3 }; &Compiler::on::module_finalize { 4 }; };';
  @local src_ptr := &str_ptr src;
  @local src_len := &WASM::i32_load src_ptr;
  @local src_bytes := src_ptr + 4;

  # Lex + parse.
  @local toks := &lex src_bytes, src_len;
  @local prog := &parse src_bytes, src_len, toks;

  # Load strata into the registry.  Default tier is T1 (inline in
  # the user program).
  &registry_init;
  &load_strata prog;

  # Verify: exactly one keyword + one operator was registered from the
  # unified form's body, each tagged with tier T1, plus one handler
  # in each of the four phase tables.
  @local kw_count := &registry_kw_count;
  @local op_count := &registry_op_count;
  @local kw_tier  := &registry_kw_tier 0;
  @local op_tier  := &registry_op_tier 0;
  @local h_decl   := &hook_decl_count;
  @local h_call   := &hook_callsite_count;
  @local h_ann    := &hook_annotation_count;
  @local h_fin    := &hook_finalize_count;
  @local ok_count := &@and (kw_count == 1), (op_count == 1);
  @local ok_tier  := &@and (kw_tier == R_TIER_T1), (op_tier == R_TIER_T1);
  @local ok_hooks := &@and (&@and (h_decl == 1), (h_call == 1)),
                           (&@and (h_ann == 1),  (h_fin == 1));

  # State buckets §5.7.  Use the stratum's defining-AST index as the
  # stratum-bucket id; mint a fresh instance bucket via state_instance_new.
  # Verify: stratum-bucket persists across set/get/has; instance buckets
  # are isolated.
  @local strat_bucket := 42;     # arbitrary id for this test
  &state_set strat_bucket, 'count', 7;
  &state_set strat_bucket, 'name',  99;
  &state_set strat_bucket, 'count', 8;     # overwrite
  @local s_count := &state_get strat_bucket, 'count';
  @local s_name  := &state_get strat_bucket, 'name';
  @local s_has1  := &state_has strat_bucket, 'count';
  @local s_has0  := &state_has strat_bucket, 'missing';
  @local s_size  := &state_count_bucket strat_bucket;

  @local inst1 := &state_instance_new;
  @local inst2 := &state_instance_new;
  &state_set inst1, 'x', 1;
  &state_set inst2, 'x', 2;
  @local i1_x := &state_get inst1, 'x';
  @local i2_x := &state_get inst2, 'x';

  @local ok_state_count := (s_count == 8);
  @local ok_state_name  := (s_name == 99);
  @local ok_state_has1  := (s_has1 == 1);
  @local ok_state_has0  := (s_has0 == 0);
  @local ok_state_size  := (s_size == 2);
  @local ok_state_a     := &@and ok_state_count, ok_state_name;
  @local ok_state_b     := &@and ok_state_has1, ok_state_has0;
  @local ok_state       := &@and (&@and ok_state_a, ok_state_b), ok_state_size;

  @local ok_inst_1 := (i1_x == 1);
  @local ok_inst_2 := (i2_x == 2);
  @local ok_inst_3 := (inst1 != inst2);
  @local ok_inst   := &@and (&@and ok_inst_1, ok_inst_2), ok_inst_3;

  # §5.6 Module mutation.  Push three pending definitions, confirm
  # the accumulator records them in order; reset and confirm drain.
  &module_push_definition 101;
  &module_push_definition 102;
  &module_push_global     103;
  @local pend_n := &module_pending_count;
  @local pend_0 := &module_pending_get 0;
  @local pend_2 := &module_pending_get 2;
  &module_pending_reset;
  @local pend_after := &module_pending_count;
  @local ok_pend_count := (pend_n == 3);
  @local ok_pend_order := &@and (pend_0 == 101), (pend_2 == 103);
  @local ok_pend_reset := (pend_after == 0);
  @local ok_pend_a     := &@and ok_pend_count, ok_pend_order;
  @local ok_pend       := &@and ok_pend_a, ok_pend_reset;

  # §5.3/§5.5 AST handle table.  capture_template returns a fresh id;
  # clone returns a NEW id but pointing at the same AST.  AST_H_KIND
  # records the 'pre' / 'post' tag.  Use AST index `prog` (the loaded
  # program) as a stand-in node.
  @local h1 := &ast_capture_template prog, AST_HANDLE_PRE;
  @local h2 := &ast_clone h1;
  @local h3 := &ast_capture_template prog, AST_HANDLE_POST;
  @local h1_ast := &ast_handle_ast h1;
  @local h2_ast := &ast_handle_ast h2;
  @local h1_kind := &ast_handle_kind h1;
  @local h3_kind := &ast_handle_kind h3;
  @local hc := &ast_handle_count;
  @local ok_ast_distinct := (h1 != h2);
  @local ok_ast_same     := (h1_ast == h2_ast);
  @local ok_ast_kind_pre := (h1_kind == AST_HANDLE_PRE);
  @local ok_ast_kind_post := (h3_kind == AST_HANDLE_POST);
  @local ok_ast_count    := (hc == 3);
  @local ok_ast_a := &@and ok_ast_distinct, ok_ast_same;
  @local ok_ast_b := &@and ok_ast_kind_pre, ok_ast_kind_post;
  @local ok_ast_c := &@and ok_ast_a, ok_ast_b;
  @local ok_ast   := &@and ok_ast_c, ok_ast_count;

  @local ok_a := &@and ok_count, ok_tier;
  @local ok_b := &@and ok_a, ok_hooks;
  @local ok_c := &@and ok_b, ok_state;
  @local ok_d := &@and ok_c, ok_inst;
  @local ok_e := &@and ok_d, ok_pend;
  @local ok   := &@and ok_e, ok_ast;
  &@if ok,
    { &write_str 1, 'strata2 OK' },
    { &write_str 1, 'strata2 FAIL' };
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};
