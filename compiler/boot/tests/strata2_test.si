# strata2_test — smoke test for Strata 2.0 unified-form loader.
#
# Verifies that the loader recognises the new `@stratum Name := { ... }`
# unified form and registers `&Compiler::register::keyword` /
# `&Compiler::register::operator` calls from the body.
#
# Self-contained: no external piping required.  Embeds a small strata
# source bundle as a Silicon string literal, feeds it through the
# lex/parse/loader pipeline, and asserts the resulting registry shape.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';
@use '../types/types.si';
@use '../ir/nodes.si';
@use '../elab/body.si';
@use '../elab/body_scope.si';
@use '../compiler_api/ctx.si';
@use '../elab/body_rich.si';
@use '../ir/lower.si';

@fn _start:Void := {
  # Source bundle: ONE @stratum unified-form definition registering
  # one keyword + one operator AND a handler in each of the four
  # phases (decl, callSite, annotation, module_finalize).
  @local src := '@stratum Demo := { &Compiler::register::keyword \'@demo_kw\'; &Compiler::register::operator \'@@\'; &Compiler::on::decl \'@demo_kw\', { 1 }; &Compiler::on::callSite \'demo_fn\', { 2 }; &Compiler::on::annotation \'@@demo_ann\', { 3 }; &Compiler::on::module_finalize { 4 }; };';
  @local src_ptr := &str_ptr src;
  @local src_len := &WASM::i32_load src_ptr;
  @local src_bytes := src_ptr + 4;

  # Lex + parse.
  @local toks := &lex src_bytes, src_len;
  @local prog := &parse src_bytes, src_len, toks;

  # Load strata into the registry.  Default tier is T1 (inline in
  # the user program).
  &registry_init;
  &load_strata prog;

  # Verify: exactly one keyword + one operator was registered from the
  # unified form's body, each tagged with tier T1, plus one handler
  # in each of the four phase tables.
  @local kw_count := &registry_kw_count;
  @local op_count := &registry_op_count;
  @local kw_tier  := &registry_kw_tier 0;
  @local op_tier  := &registry_op_tier 0;
  @local h_decl   := &hook_decl_count;
  @local h_call   := &hook_callsite_count;
  @local h_ann    := &hook_annotation_count;
  @local h_fin    := &hook_finalize_count;
  @local ok_count := &@and (kw_count == 1), (op_count == 1);
  @local ok_tier  := &@and (kw_tier == R_TIER_T1), (op_tier == R_TIER_T1);
  @local ok_hooks := &@and (&@and (h_decl == 1), (h_call == 1)),
                           (&@and (h_ann == 1),  (h_fin == 1));

  # State buckets §5.7.  Use the stratum's defining-AST index as the
  # stratum-bucket id; mint a fresh instance bucket via state_instance_new.
  # Verify: stratum-bucket persists across set/get/has; instance buckets
  # are isolated.
  @local strat_bucket := 42;     # arbitrary id for this test
  &state_set strat_bucket, 'count', 7;
  &state_set strat_bucket, 'name',  99;
  &state_set strat_bucket, 'count', 8;     # overwrite
  @local s_count := &state_get strat_bucket, 'count';
  @local s_name  := &state_get strat_bucket, 'name';
  @local s_has1  := &state_has strat_bucket, 'count';
  @local s_has0  := &state_has strat_bucket, 'missing';
  @local s_size  := &state_count_bucket strat_bucket;

  @local inst1 := &state_instance_new;
  @local inst2 := &state_instance_new;
  &state_set inst1, 'x', 1;
  &state_set inst2, 'x', 2;
  @local i1_x := &state_get inst1, 'x';
  @local i2_x := &state_get inst2, 'x';

  @local ok_state_count := (s_count == 8);
  @local ok_state_name  := (s_name == 99);
  @local ok_state_has1  := (s_has1 == 1);
  @local ok_state_has0  := (s_has0 == 0);
  @local ok_state_size  := (s_size == 2);
  @local ok_state_a     := &@and ok_state_count, ok_state_name;
  @local ok_state_b     := &@and ok_state_has1, ok_state_has0;
  @local ok_state       := &@and (&@and ok_state_a, ok_state_b), ok_state_size;

  @local ok_inst_1 := (i1_x == 1);
  @local ok_inst_2 := (i2_x == 2);
  @local ok_inst_3 := (inst1 != inst2);
  @local ok_inst   := &@and (&@and ok_inst_1, ok_inst_2), ok_inst_3;

  # §5.6 Module mutation.  Push three pending definitions, confirm
  # the accumulator records them in order; reset and confirm drain.
  &module_push_definition 101;
  &module_push_definition 102;
  &module_push_global     103;
  @local pend_n := &module_pending_count;
  @local pend_0 := &module_pending_get 0;
  @local pend_2 := &module_pending_get 2;
  &module_pending_reset;
  @local pend_after := &module_pending_count;
  @local ok_pend_count := (pend_n == 3);
  @local ok_pend_order := &@and (pend_0 == 101), (pend_2 == 103);
  @local ok_pend_reset := (pend_after == 0);
  @local ok_pend_a     := &@and ok_pend_count, ok_pend_order;
  @local ok_pend       := &@and ok_pend_a, ok_pend_reset;

  # §5.3/§5.5 AST handle table.  capture_template returns a fresh id;
  # clone returns a NEW id but pointing at the same AST.  AST_H_KIND
  # records the 'pre' / 'post' tag.  Use AST index `prog` (the loaded
  # program) as a stand-in node.
  @local h1 := &ast_capture_template prog, AST_HANDLE_PRE;
  @local h2 := &ast_clone h1;
  @local h3 := &ast_capture_template prog, AST_HANDLE_POST;
  @local h1_ast := &ast_handle_ast h1;
  @local h2_ast := &ast_handle_ast h2;
  @local h1_kind := &ast_handle_kind h1;
  @local h3_kind := &ast_handle_kind h3;
  @local hc := &ast_handle_count;
  @local ok_ast_distinct := (h1 != h2);
  @local ok_ast_same     := (h1_ast == h2_ast);
  @local ok_ast_kind_pre := (h1_kind == AST_HANDLE_PRE);
  @local ok_ast_kind_post := (h3_kind == AST_HANDLE_POST);
  @local ok_ast_count    := (hc == 3);
  @local ok_ast_a := &@and ok_ast_distinct, ok_ast_same;
  @local ok_ast_b := &@and ok_ast_kind_pre, ok_ast_kind_post;
  @local ok_ast_c := &@and ok_ast_a, ok_ast_b;
  @local ok_ast   := &@and ok_ast_c, ok_ast_count;

  # §5.4 Type-as-data.  Verify scalar singletons + Array constructor +
  # Function constructor + Variable constructor + substitute.
  &types_init;
  @local int_kind   := &type_kind TYPE_INT_H;
  @local float_kind := &type_kind TYPE_FLOAT_H;
  @local arr_int    := &type_new_array TYPE_INT_H;
  @local arr_kind   := &type_kind arr_int;
  @local arr_elem   := &type_field arr_int, 1;
  # Use known-good (name_off=0, name_len=1) — any consistent span will
  # do; substitute compares bytes via type_span_eq.  Source isn't
  # critical since both sides reference the same bytes.
  @local var_t      := &type_new_variable 0, 1;
  @local var_kind   := &type_kind var_t;
  # Function: (T, Float) -> T
  @local params_vec := &vec_new;
  params_vec        = &vec_push params_vec, var_t;
  params_vec        = &vec_push params_vec, TYPE_FLOAT_H;
  @local fn_t       := &type_new_function var_t, params_vec;
  @local fn_kind    := &type_kind fn_t;
  # Substitute T := Int.  Result should be (Int, Float) -> Int.
  @local fn_int     := &type_substitute_one fn_t, 0, 1, TYPE_INT_H;
  @local fi_kind    := &type_kind fn_int;
  @local fi_result  := &type_field fn_int, 2;
  @local fi_p0      := &type_field fn_int, 3;
  @local fi_p1      := &type_field fn_int, 4;
  # Original template unchanged (Variable still in place).
  @local orig_result := &type_field fn_t, 2;
  @local orig_kind   := &type_kind orig_result;

  @local ok_type_scalars := &@and (int_kind == SK_INT), (float_kind == SK_FLOAT);
  @local ok_type_array   := &@and (arr_kind == SK_ARRAY), (arr_elem == TYPE_INT_H);
  @local ok_type_var     := (var_kind == SK_VARIABLE);
  @local ok_type_fn      := (fn_kind == SK_FUNCTION);
  @local ok_subst_kind   := (fi_kind == SK_FUNCTION);
  @local ok_subst_result := (fi_result == TYPE_INT_H);
  @local ok_subst_p0     := (fi_p0 == TYPE_INT_H);
  @local ok_subst_p1     := (fi_p1 == TYPE_FLOAT_H);
  @local ok_subst_orig   := (orig_kind == SK_VARIABLE);
  @local ok_ty_a := &@and ok_type_scalars, ok_type_array;
  @local ok_ty_b := &@and ok_type_var, ok_type_fn;
  @local ok_ty_c := &@and ok_subst_kind, ok_subst_result;
  @local ok_ty_d := &@and ok_subst_p0, ok_subst_p1;
  @local ok_ty_e := &@and ok_ty_a, ok_ty_b;
  @local ok_ty_f := &@and ok_ty_c, ok_ty_d;
  @local ok_ty_g := &@and ok_ty_e, ok_ty_f;
  @local ok_type := &@and ok_ty_g, ok_subst_orig;

  # §6 Diagnostics — accumulate, never throw.  Push two errors + one
  # warning; assert counts and per-row severity.
  &diag_error 'E001', 0, 'first error',  0;
  &diag_error 'E002', 0, 'second error', 'try fixing X';
  &diag_warn  'W001', 0, 'a warning',    0;
  @local dn := &diag_count;
  @local de := &diag_count_by_severity DIAG_SEV_ERROR;
  @local dw := &diag_count_by_severity DIAG_SEV_WARN;
  @local d0_sev := &diag_severity 0;
  @local d2_sev := &diag_severity 2;
  @local ok_diag_count := (dn == 3);
  @local ok_diag_split := &@and (de == 2), (dw == 1);
  @local ok_diag_sev   := &@and (d0_sev == DIAG_SEV_ERROR), (d2_sev == DIAG_SEV_WARN);
  @local ok_diag_a := &@and ok_diag_count, ok_diag_split;
  @local ok_diag   := &@and ok_diag_a, ok_diag_sev;

  # T-6 cycle detection.  Phase A: 3-node DAG (no cycle).  Phase B:
  # add a back-edge to introduce a cycle; verify it's caught and the
  # S0001 diag is appended.
  &tier_add_dep 0, 1;
  &tier_add_dep 1, 2;
  @local cycle_a := &tier_cycle_detect 3;     # expect 0
  &tier_add_dep 2, 0;                          # introduce cycle
  @local diag_before := &diag_count;
  @local cycle_b := &tier_cycle_check_and_emit 3;  # expect 1, appends S0001
  @local diag_after  := &diag_count;
  @local ok_cycle_a := (cycle_a == 0);
  @local ok_cycle_b := (cycle_b == 1);
  @local ok_cycle_diag := ((diag_after - diag_before) == 1);
  @local ok_cycle_x := &@and ok_cycle_a, ok_cycle_b;
  @local ok_cycle   := &@and ok_cycle_x, ok_cycle_diag;

  # §2 Layer 2: handler firing.  Re-load the original strata source
  # (registry was disturbed by earlier additions); fire all
  # module_finalize handlers via fire_module_finalize_handlers.
  # Verify the fire count equals the registered handler count.
  &registry_init;
  &load_strata prog;
  @local pre_fin_count := &hook_finalize_count;
  @local fired := &fire_module_finalize_handlers;
  @local ok_fire := &@and (fired == 1), (pre_fin_count == 1);

  # Now register a fresh handler and fire by token.  Reuse the
  # 'demo_fn' callSite registration the unified-form created.  The
  # source `Demo := { ... &Compiler::on::callSite 'demo_fn', { 2 };
  # ... }` registered exactly one callSite handler.
  @local call_h0_off := &hook_callsite_tok_off 0;
  @local call_h0_len := &hook_callsite_tok_len 0;
  @local cs_fired := &fire_callsite_handlers call_h0_off, call_h0_len;
  @local ok_fire_cs := (cs_fired == 1);

  @local ok_fire_all := &@and ok_fire, ok_fire_cs;

  # §5.5 ast_substitute.  Build a tiny snippet `T` (an AST_NAMESPACE
  # with one segment), capture it, substitute T -> 42 (an int literal),
  # then verify the new ast is the replacement.
  @local sub_src := 'T';
  @local sub_src_len := &WASM::i32_load (&str_ptr sub_src);
  @local sub_src_bytes := (&str_ptr sub_src) + 4;
  @local sub_toks := &lex sub_src_bytes, sub_src_len;
  @local sub_prog := &parse sub_src_bytes, sub_src_len, sub_toks;
  # The program has one element: a Namespace ['T'].
  @local sub_node := &ast_field P_AST, sub_prog, 2;
  @local sub_node_kind := &ast_kind P_AST, sub_node;
  # Allocate a replacement: a fresh AST_INT_LIT 42.
  @local repl_idx := &vec_offset P_AST;
  P_AST = &ast_int_lit P_AST, 42;
  # Get name span — seg0 of the captured Namespace.
  @local name_off := &ast_field P_AST, sub_node, REGL_NS_SEG0_OFF;
  @local name_len := &ast_field P_AST, sub_node, REGL_NS_SEG0_LEN;
  @local cap_h := &ast_capture_template sub_node, AST_HANDLE_PRE;
  @local sub_h := &ast_substitute cap_h, name_off, name_len, repl_idx;
  @local sub_ast := &ast_handle_ast sub_h;
  @local sub_ast_kind := &ast_kind P_AST, sub_ast;
  @local ok_sub_ns   := (sub_node_kind == AST_NAMESPACE);
  @local ok_sub_repl := (sub_ast == repl_idx);
  @local ok_sub_kind := (sub_ast_kind == AST_INT_LIT);
  @local ok_sub_a    := &@and ok_sub_ns, ok_sub_repl;
  @local ok_sub      := &@and ok_sub_a, ok_sub_kind;

  # §5.4 type_format.  Format the Int scalar, the (T, Float) -> T
  # function, and Array[Int]; spot-check first 3 bytes vs the
  # expected prefix.
  @local int_fmt := &type_format TYPE_INT_H;
  @local int_fmt_len := &WASM::i32_load int_fmt;
  @local int_fmt_b0  := &WASM::i32_load8_u (int_fmt + 4);    # 'I'
  @local int_fmt_b1  := &WASM::i32_load8_u (int_fmt + 5);    # 'n'
  @local int_fmt_b2  := &WASM::i32_load8_u (int_fmt + 6);    # 't'
  @local arr_fmt := &type_format arr_int;
  @local arr_fmt_len := &WASM::i32_load arr_fmt;
  @local arr_fmt_b0  := &WASM::i32_load8_u (arr_fmt + 4);    # 'A'
  @local ok_fmt_int   := &@and (int_fmt_len == 3),
                              (&@and (int_fmt_b0 == 73), (int_fmt_b1 == 110));
  @local ok_fmt_int_x := &@and (int_fmt_b2 == 116), (arr_fmt_b0 == 65);
  @local ok_fmt_arr   := (arr_fmt_len == 10);              # "Array[Int]" = 10
  @local ok_fmt_a := &@and ok_fmt_int, ok_fmt_int_x;
  @local ok_fmt   := &@and ok_fmt_a, ok_fmt_arr;

  @local ok_a := &@and ok_count, ok_tier;
  @local ok_b := &@and ok_a, ok_hooks;
  @local ok_c := &@and ok_b, ok_state;
  @local ok_d := &@and ok_c, ok_inst;
  @local ok_e := &@and ok_d, ok_pend;
  @local ok_f := &@and ok_e, ok_ast;
  @local ok_g := &@and ok_f, ok_type;
  @local ok_h := &@and ok_g, ok_diag;
  @local ok_i := &@and ok_h, ok_cycle;
  @local ok_j := &@and ok_i, ok_fire_all;
  @local ok_k := &@and ok_j, ok_sub;
  @local ok   := &@and ok_k, ok_fmt;
  &@if ok,
    { &write_str 1, 'strata2 OK' },
    { &write_str 1, 'strata2 FAIL' };
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};
