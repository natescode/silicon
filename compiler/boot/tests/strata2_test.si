# strata2_test — smoke test for Strata 2.0 unified-form loader.
#
# Verifies that the loader recognises the new `@stratum Name := { ... }`
# unified form and registers `&Compiler::register::keyword` /
# `&Compiler::register::operator` calls from the body.
#
# Self-contained: no external piping required.  Embeds a small strata
# source bundle as a Silicon string literal, feeds it through the
# lex/parse/loader pipeline, and asserts the resulting registry shape.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';

@fn _start:Void := {
  # Source bundle: ONE @stratum unified-form definition registering
  # one keyword + one operator AND a handler in each of the four
  # phases (decl, callSite, annotation, module_finalize).
  @local src := '@stratum Demo := { &Compiler::register::keyword \'@demo_kw\'; &Compiler::register::operator \'@@\'; &Compiler::on::decl \'@demo_kw\', { 1 }; &Compiler::on::callSite \'demo_fn\', { 2 }; &Compiler::on::annotation \'@@demo_ann\', { 3 }; &Compiler::on::module_finalize { 4 }; };';
  @local src_ptr := &str_ptr src;
  @local src_len := &WASM::i32_load src_ptr;
  @local src_bytes := src_ptr + 4;

  # Lex + parse.
  @local toks := &lex src_bytes, src_len;
  @local prog := &parse src_bytes, src_len, toks;

  # Load strata into the registry.  Default tier is T1 (inline in
  # the user program).
  &registry_init;
  &load_strata prog;

  # Verify: exactly one keyword + one operator was registered from the
  # unified form's body, each tagged with tier T1, plus one handler
  # in each of the four phase tables.
  @local kw_count := &registry_kw_count;
  @local op_count := &registry_op_count;
  @local kw_tier  := &registry_kw_tier 0;
  @local op_tier  := &registry_op_tier 0;
  @local h_decl   := &hook_decl_count;
  @local h_call   := &hook_callsite_count;
  @local h_ann    := &hook_annotation_count;
  @local h_fin    := &hook_finalize_count;
  @local ok_count := &@and (kw_count == 1), (op_count == 1);
  @local ok_tier  := &@and (kw_tier == R_TIER_T1), (op_tier == R_TIER_T1);
  @local ok_hooks := &@and (&@and (h_decl == 1), (h_call == 1)),
                           (&@and (h_ann == 1),  (h_fin == 1));
  @local ok       := &@and (&@and ok_count, ok_tier), ok_hooks;
  &@if ok,
    { &write_str 1, 'strata2 OK' },
    { &write_str 1, 'strata2 FAIL' };
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};
