# JSON serializer driver — reads one fixture from stdin and writes its
# parse-only AST as JSON to stdout.  Used by the corpus harness which
# spawns one wasmer process per input file.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../parser/json.si';

@fn run := {
  @local cap := 65536;
  @local buf := &arena_alloc cap;
  @local total := 0;
  &@loop 1, {
    @local n := &read_bytes 0, (buf + total), (cap - total);
    &@if (n <= 0), { &@break };
    total = total + n;
    &@if (total >= cap), { &@break };
  };

  @local toks := &lex buf, total;
  @local root := &parse buf, total, toks;
  &json_program root;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
