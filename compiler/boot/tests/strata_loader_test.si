# Strata loader → JSON dump.  Reads a strata source bundle from stdin
# and emits the registry as sorted JSON.  The bun-side test diffs
# the output byte-for-byte against Stage 0's equivalent dump.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';
@use '../strata/registry_json.si';

@fn run := {
  @local cap := 65536;
  @local buf := &arena_alloc cap;
  @local total := 0;
  &@loop 1, {
    @local n := &read_bytes 0, (buf + total), (cap - total);
    &@if (n <= 0), { &@break };
    total = total + n;
    &@if (total >= cap), { &@break };
  };

  @local toks := &lex buf, total;
  @local prog := &parse buf, total, toks;
  &registry_init;
  &load_strata prog;
  &registry_dump_json;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
