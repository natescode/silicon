# Elaborator slice 1 — feeds stdin through lex → parse → load_strata
# → elaborate_program and emits a JSON document describing the
# elaboration result.  The bun-side test diffs byte-for-byte against
# Stage 0's equivalent dump.
#
# Output shape:
#
#   {
#     "definitions": [
#       { "keyword": "@let", "name": "x",   "hook": "function" },
#       { "keyword": "@var", "name": "y",   "hook": "global"   },
#       ...
#     ],
#     "errors": [ { "keyword": "@unknown" }, ... ]
#   }
#
# Definitions are emitted in source order (the order the elaborator
# walks them).  Errors are emitted in the order they were collected.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';
@use '../elab/elaborator.si';

# Field offsets within an AST_DEFINITION record (mirrors ast.si).
@let DEF_NAME_OFF:Int := 3;
@let DEF_NAME_LEN:Int := 4;
@let DEF_KW_OFF:Int   := 1;
@let DEF_KW_LEN:Int   := 2;

@fn jw_byte b:Int := { &write_byte 1, b; };
@fn jw_str  s:String := { &write_str  1, s; };
@fn jw_quoted_span off:Int, len:Int := {
  &jw_byte 34;
  &write_bytes 1, (P_SRC + off), len;
  &jw_byte 34;
};

@fn dump_elaboration := {
  &jw_byte 123; &jw_byte 10;                       # {

  # definitions
  &jw_str '  "definitions": [';
  @local n_def := &elab_def_count;
  &@if (n_def > 0), { &jw_byte 10; };
  @local i := 0;
  &@loop (i < n_def), {
    @local elem := &elab_def_at i;
    @local kw_off := &ast_field P_AST, elem, DEF_KW_OFF;
    @local kw_len := &ast_field P_AST, elem, DEF_KW_LEN;
    @local nm_off := &ast_field P_AST, elem, DEF_NAME_OFF;
    @local nm_len := &ast_field P_AST, elem, DEF_NAME_LEN;
    @local hk_off := &elab_hook_off i;
    @local hk_len := &elab_hook_len i;
    &jw_str '    { "keyword": ';
    &jw_quoted_span kw_off, kw_len;
    &jw_str ', "name": ';
    &jw_quoted_span nm_off, nm_len;
    &jw_str ', "hook": ';
    &jw_quoted_span hk_off, hk_len;
    &jw_str ' }';
    &@if ((i + 1) < n_def), { &jw_byte 44; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n_def > 0), { &jw_str '  '; };
  &jw_byte 93; &jw_byte 44; &jw_byte 10;            # ],

  # errors
  &jw_str '  "errors": [';
  @local n_err := &elab_err_count;
  &@if (n_err > 0), { &jw_byte 10; };
  i = 0;
  &@loop (i < n_err), {
    @local eo := &elab_err_off i;
    @local el := &elab_err_len i;
    @local ec := &elab_err_code i;
    &jw_str '    { "keyword": ';
    &jw_quoted_span eo, el;
    &jw_str ', "code": ';
    # Single ASCII digit — codes are 0..2.
    &jw_byte (48 + ec);
    &jw_str ' }';
    &@if ((i + 1) < n_err), { &jw_byte 44; };
    &jw_byte 10;
    i = i + 1;
  };
  &@if (n_err > 0), { &jw_str '  '; };
  &jw_byte 93; &jw_byte 10;                         # ]

  &jw_byte 125; &jw_byte 10;                        # }
};

@fn run := {
  @local cap := 65536;
  @local buf := &arena_alloc cap;
  @local total := 0;
  &@loop 1, {
    @local n := &read_bytes 0, (buf + total), (cap - total);
    &@if (n <= 0), { &@break };
    total = total + n;
    &@if (total >= cap), { &@break };
  };

  @local toks := &lex buf, total;
  @local prog := &parse buf, total, toks;
  &registry_init;
  &load_strata prog;
  &elab_init;
  &elaborate_program prog;
  &dump_elaboration;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
