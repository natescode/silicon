# Function-definition end-to-end test.  Lowers + emits a complete
# WAT module from the strata bundle plus user @fn definitions.

@use '../std/io.si';
@use '../std/arena.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../strata/registry.si';
@use '../strata/loader.si';
@use '../ir/nodes.si';
@use '../elab/body.si';
@use '../ir/lower.si';
@use '../emit/wat.si';

@fn run := {
  @local cap := 524288;     # 512 KiB — fits the full bootstrap source tree
  @local buf := &arena_alloc cap;
  @local total := 0;
  &@loop 1, {
    @local n := &read_bytes 0, (buf + total), (cap - total);
    &@if (n <= 0), { &@break };
    total = total + n;
    &@if (total >= cap), { &@break };
  };

  @local toks := &lex buf, total;
  @local prog := &parse buf, total, toks;
  &registry_init;
  &load_strata prog;
  &ir_init;
  &scope_init;
  &global_init;
  &litpool_init;
  &name_pool_init;
  &fn_sig_init;
  &fn_sig_register_prelude_voids;
  &ew_init;

  @local fns := &lower_program prog;
  &emit_program fns;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
