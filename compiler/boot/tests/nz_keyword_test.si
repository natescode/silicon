# nz_keyword test — proves the data-driven keyword loop works.
#
# &@nz is defined ENTIRELY in Silicon (boot/strata/builtin/logic.si).
# No branch for it in boot/ir/lower.si or src/.  The path:
#
#   user source uses &@nz v
#     → lower_call sees an unknown @-keyword
#     → falls through to body-rich generic fallback
#     → registry_kw_lookup finds @nz's elaboration
#     → try_dispatch_via_body_rich runs its semantics block
#     → body_rich dispatches the &Compiler::* calls
#     → returns IR_IF(v, ir_i32_const 1, ir_i32_const 0)
#     → stage1 emits the corresponding WAT
#
# Self-contained: no @use of any boot/* compiler internals.  Exercises
# stage1 from the outside the way a user program would.  Writes "nz OK"
# to stdout iff all three boolean-normalisation checks pass; exits 0
# (so it slots into STAGE1_PIPELINE_FIXTURES).

@use '../std/io.si';

@fn _start:Void := {
  @local zero_check := &@nz 0;       # expect 0
  @local pos_check  := &@nz 42;      # expect 1
  @local neg_check  := &@nz (0 - 5); # expect 1
  @local ok := &@and (zero_check == 0),
               (&@and (pos_check == 1), (neg_check == 1));
  &@if ok,
    { &write_str 1, 'nz OK' },
    { &write_str 1, 'nz FAIL' };
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};
