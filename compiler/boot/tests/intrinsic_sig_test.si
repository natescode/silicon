# intrinsic_sig_test — exercises boot/types/intrinsic_sig.si.
#
# Pass: "intrinsic-sig OK", exit 0.
# Fail: "intrinsic-sig FAIL <code>", exit 1.

@use '../std/io.si';
@use '../types/types.si';
@use '../types/intrinsic_sig.si';

@fn is_put_int n:Int := {
  @local hundreds := (n / 100);
  @local tens     := ((n / 10) % 10);
  @local ones     := (n % 10);
  &@if (hundreds > 0),     { &write_byte 1, (hundreds + 48); };
  &@if (((hundreds > 0) | (tens > 0)) == 1), { &write_byte 1, (tens + 48); };
  &write_byte 1, (ones + 48);
};

@fn is_die code:Int := {
  &write_str 1, 'intrinsic-sig FAIL ';
  &is_put_int code;
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 1;
};

# Assert a String name resolves to (n_params, p0, p1, result).
@fn is_assert name:String, want_n:Int, want_p0:Int, want_p1:Int, want_r:Int, code:Int := {
  @local m := &intrinsic_sig_str name;
  &@if (m != 1), { &is_die code; };
  &@if (INTR_N_PARAMS != want_n), { &is_die (code + 1); };
  &@if (((want_n >= 1) * (INTR_PARAM_0 != want_p0)) == 1), { &is_die (code + 2); };
  &@if (((want_n >= 2) * (INTR_PARAM_1 != want_p1)) == 1), { &is_die (code + 3); };
  &@if (INTR_RESULT != want_r), { &is_die (code + 4); };
};

@fn is_assert_miss name:String, code:Int := {
  @local m := &intrinsic_sig_str name;
  &@if (m != 0), { &is_die code; };
};

@fn run := {
  &types_init;

  # ── Binary arithmetic ──────────────────────────────────────
  &is_assert 'WASM::i32_add', 2, TYPE_INT_H,   TYPE_INT_H,   TYPE_INT_H,   10;
  &is_assert 'WASM::i64_sub', 2, TYPE_INT64_H, TYPE_INT64_H, TYPE_INT64_H, 20;
  &is_assert 'WASM::f32_mul', 2, TYPE_FLOAT_H, TYPE_FLOAT_H, TYPE_FLOAT_H, 30;
  &is_assert 'WASM::i32_div_s', 2, TYPE_INT_H, TYPE_INT_H,   TYPE_INT_H,   40;
  &is_assert 'WASM::i32_shl',   2, TYPE_INT_H, TYPE_INT_H,   TYPE_INT_H,   50;
  &is_assert 'WASM::i32_xor',   2, TYPE_INT_H, TYPE_INT_H,   TYPE_INT_H,   60;

  # ── Comparisons → Bool ────────────────────────────────────
  &is_assert 'WASM::i32_eq',   2, TYPE_INT_H,   TYPE_INT_H,   TYPE_BOOL_H, 70;
  &is_assert 'WASM::i64_lt_s', 2, TYPE_INT64_H, TYPE_INT64_H, TYPE_BOOL_H, 80;
  &is_assert 'WASM::f32_ge',   2, TYPE_FLOAT_H, TYPE_FLOAT_H, TYPE_BOOL_H, 90;

  # ── Unary ─────────────────────────────────────────────────
  &is_assert 'WASM::i32_clz',  1, TYPE_INT_H,   0, TYPE_INT_H,   100;
  &is_assert 'WASM::f32_sqrt', 1, TYPE_FLOAT_H, 0, TYPE_FLOAT_H, 110;

  # ── Conversions ───────────────────────────────────────────
  &is_assert 'WASM::i32_trunc_f32_s',  1, TYPE_FLOAT_H, 0, TYPE_INT_H,   120;
  &is_assert 'WASM::f32_convert_i32_s',1, TYPE_INT_H,   0, TYPE_FLOAT_H, 130;
  &is_assert 'WASM::i64_extend_i32_s', 1, TYPE_INT_H,   0, TYPE_INT64_H, 140;
  &is_assert 'WASM::i32_wrap_i64',     1, TYPE_INT64_H, 0, TYPE_INT_H,   150;

  # ── Memory loads ──────────────────────────────────────────
  &is_assert 'WASM::i32_load',    1, TYPE_INT_H, 0, TYPE_INT_H,   160;
  &is_assert 'WASM::i32_load8_u', 1, TYPE_INT_H, 0, TYPE_INT_H,   170;
  &is_assert 'WASM::i64_load',    1, TYPE_INT_H, 0, TYPE_INT64_H, 180;
  &is_assert 'WASM::f32_load',    1, TYPE_INT_H, 0, TYPE_FLOAT_H, 190;

  # ── Memory stores → Unknown/Void ──────────────────────────
  &is_assert 'WASM::i32_store',  2, TYPE_INT_H, TYPE_INT_H,   TYPE_UNKNOWN_H, 200;
  &is_assert 'WASM::i32_store8', 2, TYPE_INT_H, TYPE_INT_H,   TYPE_UNKNOWN_H, 210;
  &is_assert 'WASM::i64_store',  2, TYPE_INT_H, TYPE_INT64_H, TYPE_UNKNOWN_H, 220;
  &is_assert 'WASM::f32_store',  2, TYPE_INT_H, TYPE_FLOAT_H, TYPE_UNKNOWN_H, 230;

  # ── Misc ──────────────────────────────────────────────────
  &is_assert 'WASM::data_memory', 0, 0, 0, TYPE_INT_H, 240;
  &is_assert 'WASM::mem_grow',    1, TYPE_INT_H, 0, TYPE_INT_H, 250;

  # IR:: prefix is treated identically.
  &is_assert 'IR::i32_add', 2, TYPE_INT_H, TYPE_INT_H, TYPE_INT_H, 260;
  &is_assert 'IR::f32_eq',  2, TYPE_FLOAT_H, TYPE_FLOAT_H, TYPE_BOOL_H, 270;

  # ── Misses ────────────────────────────────────────────────
  &is_assert_miss 'i32_add',           300;   # no namespace prefix
  &is_assert_miss 'WASM::control_if',  310;
  &is_assert_miss 'WASM::control_loop',320;
  &is_assert_miss 'WASM::i32_bogus',   330;
  &is_assert_miss 'IR::def_global',    340;

  &write_str 1, 'intrinsic-sig OK';
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
