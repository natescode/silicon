# check_array_test — slice 2e-vi container literal checking.
#
# Pass: "check-array OK", exit 0.
# Fail: "check-array FAIL <code>", exit 1.

@use '../std/io.si';
@use '../parser/tokens.si';
@use '../parser/lex.si';
@use '../parser/ast.si';
@use '../parser/parse.si';
@use '../types/types.si';
@use '../types/ctx.si';
@use '../types/errors.si';
@use '../types/check.si';

@fn ca_put_int n:Int := {
  @local hundreds := (n / 100);
  @local tens     := ((n / 10) % 10);
  @local ones     := (n % 10);
  &@if (hundreds > 0),     { &write_byte 1, (hundreds + 48); };
  &@if (((hundreds > 0) | (tens > 0)) == 1), { &write_byte 1, (tens + 48); };
  &write_byte 1, (ones + 48);
};

@fn ca_die code:Int := {
  &write_str 1, 'check-array FAIL ';
  &ca_put_int code;
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 1;
};

@fn ca_parse_top:Int src:String := {
  @local p := (&str_ptr src) + 4;
  @local n := &str_len src;
  @local toks := &lex p, n;
  @local prog := &parse p, n, toks;
  &ast_field P_AST, prog, 2
};

@fn run := {
  &types_init;
  &errors_init;
  &ctx_init;

  # ── Homogeneous Int array ─────────────────────────────────
  @local t := &check_node (&ca_parse_top '$[1, 2, 3];');
  &@if ((&type_kind t) != SK_ARRAY),    { &ca_die 10; };
  &@if ((&type_field t, 1) != TYPE_INT_H), { &ca_die 11; };

  # ── Float array ───────────────────────────────────────────
  @local tf := &check_node (&ca_parse_top '$[1.0, 2.5];');
  &@if ((&type_field tf, 1) != TYPE_FLOAT_H), { &ca_die 20; };

  # ── Heterogeneous array pushes EK_HETEROGENEOUS ───────────
  @local errs := &err_count;
  @local th := &check_node (&ca_parse_top '$[1, @true];');
  &@if ((&type_kind th) != SK_ARRAY),            { &ca_die 30; };
  &@if ((&err_count) != (errs + 1)),             { &ca_die 31; };
  &@if ((&err_kind errs) != EK_HETEROGENEOUS),   { &ca_die 32; };

  # ── Empty array → Array<Unknown> (well-formed handle) ─────
  @local te := &check_node (&ca_parse_top '$[];');
  &@if ((&type_kind te) != SK_ARRAY), { &ca_die 40; };

  &write_str 1, 'check-array OK';
  &write_byte 1, 10;
  &wasi_snapshot_preview1::proc_exit 0;
};

&run;
