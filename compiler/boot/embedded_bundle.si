@let EMBEDDED_BUNDLE:String := '@stratum_operator BitOr (\'|\', Node) = {\n  &IR::i32_or Node.left, Node.right;\n};\n\n@stratum_operator BitXor (\'^\', Node) = {\n  &IR::i32_xor Node.left, Node.right;\n};\n\n@stratum_operator Shl (\'<<\', Node) = {\n  &IR::i32_shl Node.left, Node.right;\n};\n\n@stratum_operator Shr (\'>>\', Node) = {\n  &IR::i32_shr_s Node.left, Node.right;\n};\n\n@stratum_keyword ToFloat (\'@toFloat\', Node) = {\n  &IR::f32_convert_i32_s;\n};\n\n@stratum_keyword ToInt (\'@toInt\', Node) = {\n  &IR::i32_trunc_f32_s;\n};\n\n# Int → Int64 (sign-extend i32 to i64).\n@stratum_keyword ToInt64 (\'@toInt64\', Node) = {\n  &IR::i64_extend_i32_s;\n};\n\n# Int64 → Int (wrap, dropping the high 32 bits).\n# Overloads @toInt — the typed-keyword dispatch picks this variant when\n# the operand is Int64; the Float variant above stays in place for f32 args.\n@stratum_keyword ToIntFromInt64 (\'@toInt\', Node) = {\n  &IR::i32_wrap_i64;\n};\n\n@stratum_keyword Break (\'@break\', Node) = {\n  &IR::control_break;\n  @local id := &Compiler::ctx::loopStack::peek;\n  &Compiler::assertDefined id, \'@break outside @loop\';\n  &Compiler::ir::makeBreak id;\n};\n\n@stratum_keyword Continue (\'@continue\', Node) = {\n  &IR::control_continue;\n  @local id := &Compiler::ctx::loopStack::peek;\n  &Compiler::assertDefined id, \'@continue outside @loop\';\n  &Compiler::ir::makeContinue id;\n};\n\n@stratum_keyword Return (\'@return\', Node) = {\n  &IR::control_return;\n  @local valN  := &Compiler::arg Node, 0;\n  @local value := &Compiler::lowerExprIfDefined valN;\n  &Compiler::ir::makeReturn value;\n};\n\n# LetDef carries the rich body for the \'function\' codegen kind.  FnDef\n# registers the same dispatch intrinsic, so the LetDef expander handles both.\n@stratum_keyword LetDef (\'@let\', Node) = {\n  &IR::def_function;\n  @local name       := &Compiler::watId Node.name.name;\n  @local params     := &Compiler::lowerParams Node;\n  @local funcResult := &Compiler::lowerFunctionBody Node, params;\n  @local body       := funcResult.body;\n  @local locals     := funcResult.locals;\n  @local returnType := &Compiler::resolveFunctionReturnType Node, name, body;\n  &Compiler::ctx::globals::set name, \'i32\';\n  &Compiler::ir::makeFunction name, params, returnType, locals, body;\n};\n\n@stratum_keyword FnDef (\'@fn\', Node) = {\n  &IR::def_function;\n};\n\n@stratum_keyword VarDef (\'@var\', Node) = {\n  &IR::def_global;\n  @local name      := &Compiler::watId Node.name.name;\n  @local declared  := &Compiler::resolveType Node.name.typeAnnotation;\n  @local initInfo  := &Compiler::lowerGlobalInit Node, declared;\n  @local init      := initInfo.init;\n  @local wasmType  := initInfo.wasmType;\n  &Compiler::ctx::globals::set name, wasmType;\n  &Compiler::ctx::varNames::add name;\n  &Compiler::ir::makeGlobal name, wasmType, @true, init;\n};\n\n@stratum_keyword ExternDef (\'@extern\', Node) = {\n  &IR::def_extern;\n  @local name   := &Compiler::watId Node.name.name;\n  @local params := &Compiler::lowerExternParams Node;\n  @local result := &Compiler::lowerExternResult Node;\n  &Compiler::ir::makeImport \'env\', name, name, params, result;\n};\n\n@stratum_keyword TypeAliasDef (\'@type_alias\', Node) = {\n  &IR::def_type_alias;\n};\n\n@stratum_keyword TypeDistinctDef (\'@type_distinct\', Node) = {\n  &IR::def_type_distinct;\n};\n\n@stratum_keyword TypeSumDef (\'@type_sum\', Node) = {\n  &IR::def_type_sum;\n};\n\n@stratum_keyword EnumDef (\'@enum\', Node) = {\n  &IR::def_type_sum;\n};\n\n@stratum_keyword TypeRecordDef (\'@type\', Node) = {\n  &IR::def_type_record;\n};\n\n@stratum_keyword LocalDef (\'@local\', Node) = {\n  &IR::def_local;\n  @local wasmType := &Compiler::resolveType Node.name.typeAnnotation;\n  @local sname    := &Compiler::watId Node.name.name;\n  @local decl     := &Compiler::ir::makeLocal sname, wasmType;\n  &Compiler::ctx::pendingLocals::push decl;\n  &Compiler::ctx::locals::set sname, wasmType;\n  &IR::null;\n};\n\n@stratum_keyword If (\'@if\', Node) = {\n  &IR::control_if;\n  @local condN := &Compiler::arg Node, 0;\n  @local thenN := &Compiler::arg Node, 1;\n  @local elseN := &Compiler::arg Node, 2;\n  @local cond  := &Compiler::lowerExpr condN;\n  @local then  := &Compiler::lowerExpr thenN;\n  @local else_ := &Compiler::lowerExprIfDefined elseN;\n  &Compiler::ir::makeIf cond, then, else_;\n};\n\n@stratum_operator Or (\'||\', Node) = {\n  &IR::control_or;\n};\n\n@stratum_keyword Not (\'@not\', Node) = {\n  &IR::i32_eqz;\n};\n\n@stratum_keyword And (\'@and\', Node) = {\n  &IR::control_and;\n  @local leftN  := &Compiler::arg Node, 0;\n  @local rightN := &Compiler::arg Node, 1;\n  @local left   := &Compiler::lowerExpr leftN;\n  @local right  := &Compiler::lowerExpr rightN;\n  @local zero   := &Compiler::ir::makeConst 0, \'i32\';\n  &Compiler::ir::makeIf left, right, zero, \'i32\';\n};\n\n# Keyword form of || for &@or call-sites.  The `||` operator itself is handled\n# specially in lowerBinaryOp; this rich body covers the &@or path so the\n# expander registry has full short-circuit coverage.\n@stratum_keyword OrKw (\'@or\', Node) = {\n  &IR::control_or;\n  @local leftN  := &Compiler::arg Node, 0;\n  @local rightN := &Compiler::arg Node, 1;\n  @local left   := &Compiler::lowerExpr leftN;\n  @local right  := &Compiler::lowerExpr rightN;\n  @local one    := &Compiler::ir::makeConst 1, \'i32\';\n  &Compiler::ir::makeIf left, one, right, \'i32\';\n};\n\n# &@nz v  →  1 if v != 0 else 0.  Boolean normalisation — useful when\n# you need a 0/1 bool regardless of what non-zero number the source\n# produced.\n#\n# This is the first KEYWORD ADDED PURELY IN SILICON: there is no\n# @nz branch anywhere in boot/ir/lower.si or src/.  The strata loader\n# registers it, body_rich dispatches it via its generic fallback for\n# @-prefixed calls, and stage1 lowers it to an if-1-else-0.  Edit-\n# then-regen-then-rebuild propagates the change without any TS step.\n#\n# NOTE: the &IR::<dispatch-kind> first-call marker that other keyword\n# strata use (e.g. @if\'s &IR::control_if;) is intentionally omitted\n# here — stage1\'s strata loader has a latent bug where two keywords\n# sharing the same first-call marker confuses boot.wasm\'s compile\n# pipeline (manifests as a Pointer-out-of-bounds in fd_read).  Worth\n# tracking down for a future fix; for now the workaround is to skip\n# the marker and let body_rich\'s generic-fallback handle dispatch\n# purely by keyword name.\n@stratum_keyword NotZero (\'@nz\', Node) = {\n  @local vN   := &Compiler::arg Node, 0;\n  @local v    := &Compiler::lowerExpr vN;\n  @local one  := &Compiler::ir::makeConst 1, \'i32\';\n  @local zero := &Compiler::ir::makeConst 0, \'i32\';\n  &Compiler::ir::makeIf v, one, zero;\n};\n\n# @const name := <int-literal> — like @var but conceptually immutable.\n# First DEFINITION KEYWORD added purely in Silicon.  No branch in\n# lower.si: lower_definition\'s pass-2 hook (try_dispatch_def_via_\n# body_rich) routes it through body_rich, which dispatches the\n# &Compiler::ir::makeGlobal call into a side-effecting global_add.\n# Same int/bool-literal init constraint as stage1\'s hardcoded @var.\n#\n# Body intentionally omits the &IR::def_<kind> marker that other\n# def-keyword strata use (e.g. @var\'s &IR::def_global;).  TS Stage\n# 0\'s strata loader indexes defExpanders by codegen kind, not by\n# keyword — so registering @const with codegen kind "global" would\n# OVERWRITE @var\'s defExpander with @const\'s body, and any later\n# @var usage in Stage-0-compiled source would dispatch through\n# @const\'s body and call makeGlobal with one arg, producing an\n# IRGlobal(init=undefined) that emit then chokes on.  Skipping the\n# marker leaves Stage 0 with no @const dispatch (fine: Stage 0\n# compiles no @const usages), while stage1\'s\n# try_dispatch_def_via_body_rich finds the keyword by name via\n# registry_kw_lookup and runs body_rich as designed.\n@stratum_keyword Const (\'@const\', Node) = {\n  &Compiler::ir::makeGlobal Node;\n};\n\n# @loc name := <expr>  —  user-side analog of @local that demonstrates\n# the body_rich local-declaration path end-to-end.  Used at statement\n# position inside a function body, just like @local.\n#\n# Routes:\n#   lower_expr sees AST_DEFINITION with kw=@loc\n#     → try_dispatch_def_via_body_rich (inline-position hook in\n#       lower_expr\'s AST_DEFINITION branch)\n#     → body_rich runs the body below\n#     → &Compiler::ir::makeLocal sname, wasmType (returns sname handle)\n#     → &Compiler::ctx::pendingLocals::push (no-op in stage1)\n#     → &Compiler::ctx::locals::set sname, wasmType\n#         → real bridge in boot/compiler_api/ctx.si calls scope_push,\n#           which appends to LSCOPE and bumps the next-slot counter\n#     → body returns IR::null (the @loc *declaration* produces no\n#       IR; the binding part is currently dropped — user must follow\n#       with a separate assignment if they want the local\n#       initialized)\n#\n# Stage1\'s lower_definition now uses (vec_len LSCOPE) - n_params as\n# the function\'s n_locals, so the freshly-pushed local IS counted in\n# the emitted (local i32 …) declarations.\n@stratum_keyword Loc (\'@loc\', Node) = {\n  @local wasmType := &Compiler::resolveType Node.name.typeAnnotation;\n  @local sname    := &Compiler::watId Node.name.name;\n  @local decl     := &Compiler::ir::makeLocal sname, wasmType;\n  &Compiler::ctx::pendingLocals::push decl;\n  &Compiler::ctx::locals::set sname, wasmType;\n  # Binding (`@loc x := <expr>`) handled by makeLocalSet.  Returns\n  # IR_NONE for declaration-only `@loc x;` forms, ir_local_set\n  # otherwise — both are valid body results.  Does NOT mirror TS\n  # Stage 0\'s CompilerAPI surface today (TS doesn\'t have\n  # makeLocalSet); when @local proper gets wired through this same\n  # path, makeLocalSet needs to land on the TS side too.\n  &Compiler::ir::makeLocalSet Node;\n};\n\n@stratum_keyword Loop (\'@loop\', Node) = {\n  &IR::control_loop;\n  @local condN := &Compiler::arg Node, 0;\n  @local bodyN := &Compiler::arg Node, 1;\n  @local id    := &Compiler::ctx::nextLoopId;\n  &Compiler::ctx::loopStack::push id;\n  @local cond  := &Compiler::lowerExpr condN;\n  @local body  := &Compiler::lowerExpr bodyN;\n  &Compiler::ctx::loopStack::pop;\n  &Compiler::ir::makeLoop id, cond, body;\n};\n\n@stratum_keyword Match (\'@match\', Node) = {\n  &IR::control_match;\n  &Compiler::expandMatchChain Node, inferredType;\n};\n\n@stratum_keyword ExportDecl (\'@export\', Node) = {\n  &IR::meta_export;\n  @local sname := &Compiler::watId Node.name.name;\n  @local isVar := &Compiler::isVarName sname;\n  @local kind  := &Compiler::choose isVar, \'global\', \'func\';\n  &Compiler::ir::makeExport sname, sname, kind;\n};\n\n@stratum_keyword PlatformDecl (\'@platform\', Node) = {\n  &IR::meta_platform;\n  &IR::null;\n};\n\n@stratum_operator Plus (\'+\', Node) = {\n  &IR::i32_add Node.left, Node.right;\n};\n\n@stratum_operator Minus (\'-\', Node) = {\n  &IR::i32_sub Node.left, Node.right;\n};\n\n@stratum_operator Multiply (\'*\', Node) = {\n  &IR::i32_mul Node.left, Node.right;\n};\n\n@stratum_operator Divide (\'/\', Node) = {\n  &IR::i32_div_s Node.left, Node.right;\n};\n\n@stratum_operator Modulo (\'%\', Node) = {\n  &IR::i32_rem_s Node.left, Node.right;\n};\n\n@stratum_operator Equal (\'==\', Node) = {\n  &IR::i32_eq Node.left, Node.right;\n};\n\n@stratum_operator NotEqual (\'!=\', Node) = {\n  &IR::i32_ne Node.left, Node.right;\n};\n\n@stratum_operator LessThan (\'<\', Node) = {\n  &IR::i32_lt_s Node.left, Node.right;\n};\n\n@stratum_operator GreaterThan (\'>\', Node) = {\n  &IR::i32_gt_s Node.left, Node.right;\n};\n\n@stratum_operator LessThanOrEqual (\'<=\', Node) = {\n  &IR::i32_le_s Node.left, Node.right;\n};\n\n@stratum_operator GreaterThanOrEqual (\'>=\', Node) = {\n  &IR::i32_ge_s Node.left, Node.right;\n};\n\n@stratum_operator PlusFloat (\'+\', Node) = {\n  &IR::f32_add Node.left, Node.right;\n};\n\n@stratum_operator MinusFloat (\'-\', Node) = {\n  &IR::f32_sub Node.left, Node.right;\n};\n\n@stratum_operator MultiplyFloat (\'*\', Node) = {\n  &IR::f32_mul Node.left, Node.right;\n};\n\n@stratum_operator DivideFloat (\'/\', Node) = {\n  &IR::f32_div Node.left, Node.right;\n};\n\n@stratum_operator EqualFloat (\'==\', Node) = {\n  &IR::f32_eq Node.left, Node.right;\n};\n\n@stratum_operator NotEqualFloat (\'!=\', Node) = {\n  &IR::f32_ne Node.left, Node.right;\n};\n\n@stratum_operator LessThanFloat (\'<\', Node) = {\n  &IR::f32_lt Node.left, Node.right;\n};\n\n@stratum_operator GreaterThanFloat (\'>\', Node) = {\n  &IR::f32_gt Node.left, Node.right;\n};\n\n@stratum_operator LessThanOrEqualFloat (\'<=\', Node) = {\n  &IR::f32_le Node.left, Node.right;\n};\n\n@stratum_operator GreaterThanOrEqualFloat (\'>=\', Node) = {\n  &IR::f32_ge Node.left, Node.right;\n};\n\n# Int64 overloads — registered under the compound key `${op}:Int64`.\n# Operator dispatch in lowerBinaryOp picks these when both operands\n# are Int64; the plain Int (i32) entries above stay primary.\n@stratum_operator PlusInt64 (\'+\', Node) = {\n  &IR::i64_add Node.left, Node.right;\n};\n\n@stratum_operator MinusInt64 (\'-\', Node) = {\n  &IR::i64_sub Node.left, Node.right;\n};\n\n@stratum_operator MultiplyInt64 (\'*\', Node) = {\n  &IR::i64_mul Node.left, Node.right;\n};\n\n@stratum_operator DivideInt64 (\'/\', Node) = {\n  &IR::i64_div_s Node.left, Node.right;\n};\n\n@stratum_operator ModuloInt64 (\'%\', Node) = {\n  &IR::i64_rem_s Node.left, Node.right;\n};\n\n@stratum_operator EqualInt64 (\'==\', Node) = {\n  &IR::i64_eq Node.left, Node.right;\n};\n\n@stratum_operator NotEqualInt64 (\'!=\', Node) = {\n  &IR::i64_ne Node.left, Node.right;\n};\n\n@stratum_operator LessThanInt64 (\'<\', Node) = {\n  &IR::i64_lt_s Node.left, Node.right;\n};\n\n@stratum_operator GreaterThanInt64 (\'>\', Node) = {\n  &IR::i64_gt_s Node.left, Node.right;\n};\n\n@stratum_operator LessThanOrEqualInt64 (\'<=\', Node) = {\n  &IR::i64_le_s Node.left, Node.right;\n};\n\n@stratum_operator GreaterThanOrEqualInt64 (\'>=\', Node) = {\n  &IR::i64_ge_s Node.left, Node.right;\n};\n\n@stratum_operator Concat (\'++\', Node) = {\n  &str_concat Node.left, Node.right;\n};\n\n';
