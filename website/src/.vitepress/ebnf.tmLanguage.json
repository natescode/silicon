{
  "name": "ebnf",
  "scopeName": "source.ebnf",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#rule" },
    { "include": "#group" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.ebnf",
      "begin": "\\(\\*",
      "end": "\\*\\)"
    },
    "string": {
      "patterns": [
        { "name": "string.quoted.double.ebnf", "match": "\"[^\"]*\"" },
        { "name": "string.quoted.single.ebnf", "match": "'[^']*'" }
      ]
    },
    "rule": {
      "match": "^\\s*([A-Za-z][A-Za-z0-9_-]*)\\s*(=)",
      "captures": {
        "1": { "name": "entity.name.function.ebnf" },
        "2": { "name": "keyword.operator.definition.ebnf" }
      }
    },
    "group": {
      "name": "punctuation.section.group.ebnf",
      "match": "[\\[\\]{}()]"
    },
    "operator": {
      "name": "keyword.operator.ebnf",
      "match": "[|;,*+?-]"
    }
  }
}
